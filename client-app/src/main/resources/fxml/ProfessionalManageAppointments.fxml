<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="650.0" prefWidth="900.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.piedraazul.app_client.controllers.ProfessionalManageAppointmentsController">
   <children>

      <!-- ══ HEADER ══ -->
      <AnchorPane prefHeight="100.0" prefWidth="900.0" styleClass="header--patient-gradient">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="0.0"
                  AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
               <children>

                  <!-- Títulos -->
                  <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" spacing="4.0">
                     <children>
                        <Label text="GESTIONAR CITA" textFill="WHITE">
                           <font><Font name="Cascadia Code Bold" size="24.0" /></font>
                        </Label>
                        <Label text="Panel del Profesional" textFill="#dce0ff">
                           <font><Font name="Cascadia Code" size="13.0" /></font>
                        </Label>
                     </children>
                     <padding><Insets left="30.0" /></padding>
                  </VBox>

                  <!-- Botón Regresar -->
                  <Button mnemonicParsing="false" onAction="#handleReturn"
                          prefHeight="36.0" prefWidth="140.0"
                          styleClass="btn--ghost-white"
                          text="← Regresar">
                     <font><Font name="Cascadia Code Bold" size="13.0" /></font>
                     <HBox.margin><Insets right="25.0" /></HBox.margin>
                  </Button>

               </children>
            </HBox>
         </children>
      </AnchorPane>

      <!-- ══ BODY ══ -->
      <AnchorPane VBox.vgrow="ALWAYS" prefWidth="900.0" styleClass="page--gradient-light">
         <children>
            <VBox spacing="16.0"
                  AnchorPane.bottomAnchor="24.0" AnchorPane.leftAnchor="30.0"
                  AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="24.0">
               <children>

                  <!-- ── Tarjeta de búsqueda ── -->
                  <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="appointments__card">
                     <children>
                        <Label text="🔍  Cédula del paciente:" styleClass="appointments__section-title">
                           <font><Font name="Cascadia Code Bold" size="13.0" /></font>
                        </Label>
                        <TextField fx:id="txtCedula"
                                   prefHeight="36.0" prefWidth="240.0"
                                   promptText="Ingrese identificación"
                                   styleClass="textfield--styled"
                                   HBox.hgrow="NEVER" />
                        <Button mnemonicParsing="false" onAction="#handleFind"
                                prefHeight="36.0" prefWidth="110.0"
                                styleClass="btn--patient-primary"
                                text="Buscar">
                           <font><Font name="Cascadia Code Bold" size="13.0" /></font>
                        </Button>
                     </children>
                     <padding><Insets top="14.0" right="20.0" bottom="14.0" left="20.0" /></padding>
                  </HBox>

                  <!-- ── Tarjeta de tabla ── -->
                  <VBox styleClass="appointments__card" spacing="14.0" VBox.vgrow="ALWAYS">
                     <children>

                        <!-- Encabezado de sección -->
                        <HBox alignment="CENTER_LEFT">
                           <children>
                              <Label text="📋  Citas del Paciente"
                                     styleClass="appointments__section-title">
                                 <font><Font name="Cascadia Code Bold" size="14.0" /></font>
                              </Label>
                           </children>
                        </HBox>

                        <!-- Instrucción -->
                        <Label text="Seleccione la cita que desea modificar:"
                               styleClass="appointments__empty-label">
                           <font><Font name="Cascadia Code" size="12.0" /></font>
                        </Label>

                        <!-- Tabla de citas -->
                        <TableView fx:id="tblAppointments"
                                   VBox.vgrow="ALWAYS"
                                   maxWidth="Infinity"
                                   styleClass="appointments__table">
                           <columns>
                              <TableColumn fx:id="colId"           prefWidth="70.0"  text="ID Cita" />
                              <TableColumn fx:id="colDate"         prefWidth="100.0" text="Fecha" />
                              <TableColumn fx:id="colTime"         prefWidth="80.0"  text="Hora" />
                              <TableColumn fx:id="colPatientName"  prefWidth="130.0" text="Paciente" />
                              <TableColumn fx:id="colProfessional" prefWidth="130.0" text="Profesional" />
                              <TableColumn fx:id="colType"         prefWidth="90.0"  text="Tipo" />
                              <TableColumn fx:id="colSpeciality"   prefWidth="100.0" text="Especialidad" />
                              <TableColumn fx:id="colStatus"       prefWidth="110.0" text="Estado" />
                              <TableColumn fx:id="colDescription"  prefWidth="140.0" text="Descripción" />
                           </columns>
                           <placeholder>
                              <Label text="No se encontraron citas para este paciente."
                                     styleClass="appointments__empty-label">
                                 <font><Font name="Cascadia Code" size="13.0" /></font>
                              </Label>
                           </placeholder>
                        </TableView>

                     </children>
                     <padding><Insets top="20.0" right="20.0" bottom="20.0" left="20.0" /></padding>
                  </VBox>

                  <!-- ── Sección Cambiar Estado ── -->
                  <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="appointments__card">
                     <children>
                        <Label text="📝  Cambiar estado:" styleClass="appointments__section-title">
                           <font><Font name="Cascadia Code Bold" size="13.0" /></font>
                        </Label>
                        <ComboBox fx:id="cbxNewStatus"
                                  prefHeight="36.0" prefWidth="200.0"
                                  styleClass="combobox--styled"
                                  promptText="Seleccione estado" />
                        <Button mnemonicParsing="false" onAction="#handleChangeStatus"
                                prefHeight="38.0" prefWidth="190.0"
                                styleClass="btn--patient-primary"
                                text="Cambiar Estado">
                           <font><Font name="Cascadia Code Bold" size="13.0" /></font>
                        </Button>

                        <!-- Spacer -->
                        <Region HBox.hgrow="ALWAYS" />

                        <!-- Botones secundarios -->
                        <Button mnemonicParsing="false" onAction="#handleCancel"
                                prefHeight="38.0" prefWidth="150.0"
                                styleClass="btn--danger-rounded"
                                text="Eliminar Cita">
                           <font><Font name="Cascadia Code Bold" size="12.0" /></font>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#handleReschedule"
                                prefHeight="38.0" prefWidth="140.0"
                                styleClass="btn--warning-rounded"
                                text="Reagendar">
                           <font><Font name="Cascadia Code Bold" size="12.0" /></font>
                        </Button>
                     </children>
                     <padding><Insets top="14.0" right="20.0" bottom="14.0" left="20.0" /></padding>
                  </HBox>

               </children>
            </VBox>
         </children>
      </AnchorPane>

   </children>
</VBox>
