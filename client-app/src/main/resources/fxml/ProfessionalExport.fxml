<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.piedraazul.app_client.controllers.ProfessionalExportController">
   <children>
      <VBox layoutX="30.0" layoutY="20.0" prefHeight="660.0" prefWidth="940.0" spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="20.0">
         <children>
            <VBox alignment="CENTER" spacing="5.0" style="-fx-background-color: #5947ff; -fx-background-radius: 10;">
               <children>
                  <Label text="EXPORTACIÓN DE CITAS" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="28.0" />
                     </font>
                  </Label>
               </children>
               <padding>
                  <Insets bottom="15.0" top="15.0" />
               </padding>
            </VBox>
            
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Médico / Terapista:" textFill="#555555">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Label>
                        <ComboBox fx:id="cbxProfessional" prefHeight="35.0" prefWidth="250.0" promptText="Seleccione profesional" />
                     </children>
                  </VBox>
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Fecha de las citas:" textFill="#555555">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Label>
                        <DatePicker fx:id="dpDate" prefHeight="35.0" prefWidth="200.0" />
                     </children>
                  </VBox>
                  <VBox alignment="BOTTOM_CENTER">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleFind" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #5947ff; -fx-text-fill: white; -fx-font-weight: bold;" text="Buscar" />
                     </children>
                  </VBox>
                  <VBox alignment="BOTTOM_CENTER">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleClear" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #e8e8e8; -fx-text-fill: #333;" text="Borrar Filtro" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            
            <VBox spacing="10.0" VBox.vgrow="ALWAYS">
               <children>
                  <Label text="Citas encontradas:" textFill="#555555">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Label>
                  <TableView fx:id="tblAppointments" prefHeight="200.0" prefWidth="200.0" style="-fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                    <columns>
                       <TableColumn fx:id="colId" prefWidth="80.0" text="ID Cita" />
                       <TableColumn fx:id="colDate" prefWidth="110.0" text="Fecha" />
                       <TableColumn fx:id="colTime" prefWidth="100.0" text="Hora" />
                       <TableColumn fx:id="colPatientName" text="Paciente" prefWidth="150"/>
                       <TableColumn fx:id="colProfessional" text="Profesional" prefWidth="150"/>
                       <TableColumn fx:id="colType" text="Tipo" prefWidth="100"/>
                       <TableColumn fx:id="colSpeciality" text="Especialidad" prefWidth="120"/>
                       <TableColumn fx:id="colStatus" prefWidth="150.0" text="Estado" />
                       <TableColumn fx:id="colDescription" prefWidth="155.0" text="Descripción" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
            
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleReturn" prefHeight="45.0" prefWidth="180.0" style="-fx-background-color: transparent; -fx-border-color: #5947ff; -fx-border-radius: 5; -fx-text-fill: #5947ff; -fx-font-weight: bold;" text="&lt;- Regresar" />
                  <AnchorPane HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleExport" prefHeight="45.0" prefWidth="220.0" style="-fx-background-color: #46af41; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 5, 0, 0, 2);" text="Exportar citas..." />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
