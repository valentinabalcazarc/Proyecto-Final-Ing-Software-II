<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.piedraazul.app_client.controllers.SchedulerSelectSpecificAppointmentController">

   <stylesheets>
      <URL value="@stylesheet.css" />
   </stylesheets>

   <children>

      <!-- ══ HEADER ══ -->
      <AnchorPane prefHeight="110.0" prefWidth="800.0" styleClass="header--patient-gradient">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
               <children>

                  <!-- Títulos del header -->
                  <VBox alignment="CENTER_LEFT" spacing="4.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Reagendamiento de Citas" textFill="WHITE">
                           <font><Font name="Cascadia Code Bold" size="22.0" /></font>
                        </Label>
                        <Label text="Selecciona cita disponible" textFill="#dce0ff">
                           <font><Font name="Cascadia Code" size="13.0" /></font>
                        </Label>
                     </children>
                     <padding><Insets left="30.0" /></padding>
                  </VBox>

                  <!-- Ícono decorativo -->
                  <Label text="📅" textFill="WHITE">
                     <font><Font size="36.0" /></font>
                     <HBox.margin><Insets right="30.0" /></HBox.margin>
                  </Label>

               </children>
            </HBox>
         </children>
      </AnchorPane>

      <!-- ══ BODY ══ -->
      <AnchorPane prefWidth="800.0" styleClass="page--gradient-light" VBox.vgrow="ALWAYS">
         <children>
            <VBox spacing="18.0" AnchorPane.bottomAnchor="24.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="24.0">
               <children>

                  <!-- ── Tarjeta de filtros ── -->
                  <VBox spacing="14.0" styleClass="specific-app__filter-card">
                     <children>

                        <!-- Título de sección -->
                        <Label styleClass="specific-app__filter-title" text="🔍  Buscar Citas Disponibles">
                           <font><Font name="Cascadia Code Bold" size="14.0" /></font>
                        </Label>

                        <!-- Fila de filtros + botón -->
                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                           <children>

                              <!-- Campos de filtro -->
                              <VBox spacing="12.0" HBox.hgrow="ALWAYS">
                                 <children>

                                    <!-- Filtro: Profesional -->
                                    <HBox alignment="CENTER_LEFT" spacing="14.0">
                                       <children>
                                          <Label prefWidth="210.0" styleClass="specific-app__field-label" text="Médico / Terapista:">
                                             <font><Font name="Cascadia Code" size="12.0" /></font>
                                          </Label>
                                          <ComboBox fx:id="cbxProfessional" prefWidth="260.0" styleClass="combobox--styled" />
                                       </children>
                                    </HBox>

                                    <!-- Filtro: Fecha -->
                                    <HBox alignment="CENTER_LEFT" spacing="14.0">
                                       <children>
                                          <Label prefWidth="210.0" styleClass="specific-app__field-label" text="Fecha de la cita:">
                                             <font><Font name="Cascadia Code" size="12.0" /></font>
                                          </Label>
                                          <DatePicker fx:id="dpFecha" prefWidth="260.0" styleClass="datepicker--styled" />
                                       </children>
                                    </HBox>

                                 </children>
                              </VBox>

                              <!-- Botones de acción del filtro -->
                              <VBox alignment="CENTER" spacing="10.0">
                                 <children>
                                    <Button mnemonicParsing="false" onAction="#handleBuscar" prefHeight="40.0" prefWidth="140.0" styleClass="btn--patient-primary" text="🔍  Buscar">
                                       <font><Font name="Cascadia Code Bold" size="13.0" /></font>
                                    </Button>
                                    <Button mnemonicParsing="false" onAction="#handleBorrarFiltro" prefHeight="36.0" prefWidth="140.0" styleClass="btn--patient-outline" text="✕  Borrar Filtro">
                                       <font><Font name="Cascadia Code Bold" size="12.0" /></font>
                                    </Button>
                                 </children>
                              </VBox>

                           </children>
                        </HBox>

                     </children>
                     <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                  </VBox>

                  <!-- ── Tarjeta de tabla de citas ── -->
                  <VBox spacing="14.0" styleClass="appointments__card" VBox.vgrow="ALWAYS">
                     <children>

                        <!-- Encabezado de sección -->
                        <Label styleClass="appointments__section-title" text="📋  Citas Disponibles">
                           <font><Font name="Cascadia Code Bold" size="14.0" /></font>
                        </Label>

                        <!-- Tabla -->
                        <TableView fx:id="tblAppointments" maxWidth="Infinity" styleClass="appointments__table" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn fx:id="colDate" prefWidth="110.0" text="Fecha" />
                              <TableColumn fx:id="colTime" prefWidth="100.0" text="Hora" />
                              <TableColumn fx:id="colProfName" prefWidth="210.0" text="Nombre Profesional" />
                              <TableColumn fx:id="colProfType" prefWidth="160.0" text="Tipo Profesional" />
                              <TableColumn fx:id="colSpeciality" prefWidth="160.0" text="Especialidad" />
                           </columns>
                           <placeholder>
                              <Label styleClass="appointments__empty-label" text="No se encontraron citas disponibles.">
                                 <font><Font name="Cascadia Code" size="13.0" /></font>
                              </Label>
                           </placeholder>
                        </TableView>

                     </children>
                     <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                  </VBox>

                  <!-- ── Botones de navegación ── -->
                  <HBox alignment="CENTER" spacing="150.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleRegresar" prefHeight="38.0" prefWidth="160.0" styleClass="btn--patient-outline" text="← Regresar">
                           <font><Font name="Cascadia Code Bold" size="13.0" /></font>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#handleConfirmar" prefHeight="38.0" prefWidth="168.0" styleClass="btn--patient-primary" text="✔  Confirmar Cita">
                           <font><Font name="Cascadia Code Bold" size="13.0" /></font>
                        </Button>
                     </children>
                  </HBox>

               </children>
            </VBox>
         </children>
      </AnchorPane>

   </children>
</VBox>
