<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="620.0" prefWidth="680.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.piedraazul.app_client.controllers.EditProfessionalScheduleController">
    <children>

        <!-- Header -->
        <Pane prefHeight="80.0" prefWidth="680.0" styleClass="header--blue">
            <children>
                <Label layoutX="0.0" layoutY="18.0" prefWidth="680.0"
                       text="EDITAR HORARIO DEL PROFESIONAL"
                       textFill="WHITE" textAlignment="CENTER">
                    <font><Font name="Cascadia Code Bold" size="17.0"/></font>
                </Label>
                <Label fx:id="lblProfName" layoutX="0.0" layoutY="48.0"
                       prefWidth="680.0" textFill="WHITE" textAlignment="CENTER">
                    <font><Font name="Cascadia Code Regular" size="12.0"/></font>
                </Label>
            </children>
        </Pane>

        <!-- Contenido -->
        <Pane layoutY="80.0" prefHeight="540.0" prefWidth="680.0" styleClass="page--gray">
            <children>

                <!-- Card horario -->
                <Pane layoutX="24.0" layoutY="18.0"
                      prefHeight="176.0" prefWidth="632.0" styleClass="card">
                    <children>
                        <Label layoutX="20.0" layoutY="16.0" text="⏰  Horario de atención">
                            <font><Font name="Cascadia Code Bold" size="13.0"/></font>
                        </Label>

                        <!-- Hora llegada -->
                        <Label layoutX="20.0" layoutY="50.0" text="Hora llegada *">
                            <font><Font name="Cascadia Code Regular" size="11.0"/></font>
                        </Label>
                        <TextField fx:id="txtArrivalTime"
                                   layoutX="20.0" layoutY="68.0"
                                   prefWidth="276.0" promptText="HH:mm"
                                   styleClass="textfield--styled"/>
                        <Label layoutX="20.0" layoutY="95.0"
                               text="Formato 24h, ej: 08:00"
                               style="-fx-text-fill: #999999; -fx-font-size: 10px;"/>

                        <!-- Hora salida -->
                        <Label layoutX="336.0" layoutY="50.0" text="Hora salida *">
                            <font><Font name="Cascadia Code Regular" size="11.0"/></font>
                        </Label>
                        <TextField fx:id="txtDepartureTime"
                                   layoutX="336.0" layoutY="68.0"
                                   prefWidth="276.0" promptText="HH:mm"
                                   styleClass="textfield--styled"/>
                        <Label layoutX="336.0" layoutY="95.0"
                               text="Formato 24h, ej: 17:00"
                               style="-fx-text-fill: #999999; -fx-font-size: 10px;"/>

                        <!-- Intervalo -->
                        <Label layoutX="20.0" layoutY="118.0" text="Intervalo (min) *">
                            <font><Font name="Cascadia Code Regular" size="11.0"/></font>
                        </Label>
                        <TextField fx:id="txtInterval"
                                   layoutX="20.0" layoutY="136.0"
                                   prefWidth="276.0" promptText="Ej: 30"
                                   styleClass="textfield--styled"/>
                        <Label layoutX="20.0" layoutY="160.0"
                               text="Tiempo en minutos entre citas"
                               style="-fx-text-fill: #999999; -fx-font-size: 10px;"/>

                        <!-- Label error horario -->
                        <Label fx:id="lblErrorSchedule"
                               layoutX="336.0" layoutY="136.0"
                               prefWidth="276.0"
                               style="-fx-text-fill: #D94F4F; -fx-font-size: 11px;"
                               visible="false"/>
                    </children>
                </Pane>

                <!-- Card días no laborables -->
                <Pane layoutX="24.0" layoutY="210.0"
                      prefHeight="272.0" prefWidth="632.0" styleClass="card">
                    <children>
                        <Label layoutX="20.0" layoutY="16.0" text="📅  Días no laborables">
                            <font><Font name="Cascadia Code Bold" size="13.0"/></font>
                        </Label>
                        <Label layoutX="20.0" layoutY="36.0"
                               text="Agrega las fechas en las que el profesional NO estará disponible (opcional)"
                               style="-fx-text-fill: #666666; -fx-font-size: 11px;"/>

                        <!-- Fila agregar -->
                        <Label layoutX="20.0" layoutY="66.0" text="Fecha">
                            <font><Font name="Cascadia Code Regular" size="11.0"/></font>
                        </Label>
                        <Label layoutX="210.0" layoutY="66.0" text="Motivo">
                            <font><Font name="Cascadia Code Regular" size="11.0"/></font>
                        </Label>
                        <Label layoutX="210.0" layoutY="64.0"
                               text="  (opcional)"
                               style="-fx-text-fill: #9999aa; -fx-font-size: 10px; -fx-padding: 0 0 0 44;"/>

                        <DatePicker fx:id="dpUnavailableDate"
                                    layoutX="20.0" layoutY="84.0"
                                    prefWidth="176.0"/>
                        <TextField fx:id="txtUnavailableReason"
                                   layoutX="210.0" layoutY="84.0"
                                   prefWidth="330.0"
                                   promptText="Ej: Vacaciones, capacitación, cita médica..."
                                   styleClass="textfield--styled"/>
                        <Button fx:id="btnAddDay"
                                layoutX="552.0" layoutY="84.0"
                                prefHeight="30.0" prefWidth="60.0"
                                text="+ Agregar"
                                onAction="#handleAddUnavailableDay"
                                styleClass="btn--success"
                                style="-fx-font-size: 11px; -fx-background-radius: 5;"/>

                        <!-- Tabla días no laborables -->
                        <TableView fx:id="tableUnavailableDays"
                                   layoutX="20.0" layoutY="126.0"
                                   prefHeight="130.0" prefWidth="592.0"
                                   styleClass="appointments__table">
                            <columns>
                                <TableColumn fx:id="colUnavDate" text="Fecha" prefWidth="160.0"/>
                                <TableColumn fx:id="colUnavReason" text="Motivo" prefWidth="340.0"/>
                                <TableColumn fx:id="colUnavDelete" text="Eliminar" prefWidth="90.0"/>
                            </columns>
                        </TableView>
                    </children>
                </Pane>

                <!-- Botones -->
                <HBox layoutX="24.0" layoutY="496.0" spacing="12.0">
                    <Button fx:id="btnCancel"
                            prefHeight="34.0" prefWidth="150.0"
                            text="Cancelar"
                            onAction="#handleCancel"
                            styleClass="btn--secondary">
                        <font><Font name="Cascadia Code Regular" size="12.0"/></font>
                    </Button>
                    <Button fx:id="btnSave"
                            prefHeight="34.0" prefWidth="150.0"
                            text="Guardar cambios"
                            onAction="#handleSave"
                            styleClass="btn--primary">
                        <font><Font name="Cascadia Code Regular" size="12.0"/></font>
                    </Button>
                </HBox>

            </children>
        </Pane>

    </children>
</AnchorPane>
