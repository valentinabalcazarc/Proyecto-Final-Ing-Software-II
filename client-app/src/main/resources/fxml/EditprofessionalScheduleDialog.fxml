<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="620.0" prefWidth="680.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.piedraazul.app_client.controllers.EditProfessionalScheduleController">
    <children>
        <VBox AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" styleClass="page--gray">
            
            <!-- Header -->
            <VBox alignment="CENTER" spacing="5.0" styleClass="header--patient-gradient" prefHeight="80.0" style="-fx-padding: 15 0 15 0;">
                <children>
                    <Label text="EDITAR HORARIO DEL PROFESIONAL" textFill="WHITE">
                        <font><Font name="Cascadia Code Bold" size="17.0"/></font>
                    </Label>
                    <Label fx:id="lblProfName" textFill="#d0d0ff">
                        <font><Font name="Cascadia Code Regular" size="12.0"/></font>
                    </Label>
                </children>
            </VBox>

            <!-- Contenido -->
            <VBox spacing="20.0" style="-fx-padding: 24 24 24 24;" VBox.vgrow="ALWAYS">
                <children>

                    <!-- Card horario -->
                    <VBox spacing="15.0" styleClass="card--form">
                        <children>
                            <Label text="⏰  Horario de atención" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #333355;" />

                            <HBox spacing="20.0">
                                <children>
                                    <!-- Hora llegada -->
                                    <VBox spacing="4.0" HBox.hgrow="ALWAYS" prefWidth="280.0">
                                        <children>
                                            <Label text="Hora llegada *" style="-fx-font-weight: bold; -fx-font-size: 11px; -fx-text-fill: #555577;" />
                                            <TextField fx:id="txtArrivalTime" promptText="HH:mm" styleClass="textfield--styled" maxWidth="Infinity" />
                                            <Label text="Formato 24h, ej: 08:00" style="-fx-text-fill: #999999; -fx-font-size: 11px;" />
                                        </children>
                                    </VBox>

                                    <!-- Hora salida -->
                                    <VBox spacing="4.0" HBox.hgrow="ALWAYS" prefWidth="280.0">
                                        <children>
                                            <Label text="Hora salida *" style="-fx-font-weight: bold; -fx-font-size: 11px; -fx-text-fill: #555577;" />
                                            <TextField fx:id="txtDepartureTime" promptText="HH:mm" styleClass="textfield--styled" maxWidth="Infinity" />
                                            <Label text="Formato 24h, ej: 17:00" style="-fx-text-fill: #999999; -fx-font-size: 11px;" />
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>

                            <HBox spacing="20.0">
                                <children>
                                    <!-- Intervalo -->
                                    <VBox spacing="4.0" HBox.hgrow="ALWAYS" prefWidth="280.0">
                                        <children>
                                            <Label text="Intervalo (min) *" style="-fx-font-weight: bold; -fx-font-size: 11px; -fx-text-fill: #555577;" />
                                            <TextField fx:id="txtInterval" promptText="Ej: 30" styleClass="textfield--styled" maxWidth="Infinity" />
                                            <Label text="Tiempo en minutos entre citas" style="-fx-text-fill: #999999; -fx-font-size: 11px;" />
                                        </children>
                                    </VBox>

                                    <!-- Error label -->
                                    <VBox spacing="4.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" prefWidth="280.0">
                                        <children>
                                            <Label fx:id="lblErrorSchedule" text="" style="-fx-text-fill: #D94F4F; -fx-font-size: 11px; -fx-font-weight: bold;" visible="false" />
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <!-- Card días no laborables -->
                    <VBox spacing="15.0" styleClass="card--form">
                        <children>
                            <VBox spacing="2.0">
                                <children>
                                    <Label text="📅  Días no laborables" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #333355;" />
                                    <Label text="Agrega las fechas en las que el profesional NO estará disponible (opcional)" style="-fx-text-fill: #666666; -fx-font-size: 11px;" />
                                </children>
                            </VBox>

                            <!-- Fila de checkboxes -->
                            <HBox spacing="15.0" alignment="CENTER_LEFT" style="-fx-padding: 5 0 0 0;">
                                <children>
                                    <CheckBox fx:id="chkMonday" text="Lunes" styleClass="checkbox--chip" />
                                    <CheckBox fx:id="chkTuesday" text="Martes" styleClass="checkbox--chip" />
                                    <CheckBox fx:id="chkWednesday" text="Miércoles" styleClass="checkbox--chip" />
                                    <CheckBox fx:id="chkThursday" text="Jueves" styleClass="checkbox--chip" />
                                    <CheckBox fx:id="chkFriday" text="Viernes" styleClass="checkbox--chip" />
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <Pane VBox.vgrow="ALWAYS" />

                    <!-- Botones -->
                    <HBox spacing="12.0" alignment="CENTER_LEFT">
                        <children>
                            <Button fx:id="btnCancel" prefHeight="38.0" prefWidth="150.0" text="Cancelar" onAction="#handleCancel" styleClass="btn--secondary">
                                <font><Font name="Cascadia Code Regular" size="12.0"/></font>
                            </Button>
                            <Button fx:id="btnSave" prefHeight="38.0" prefWidth="160.0" text="Guardar cambios" onAction="#handleSave" styleClass="btn--primary">
                                <font><Font name="Cascadia Code Regular" size="12.0"/></font>
                            </Button>
                        </children>
                    </HBox>

                </children>
            </VBox>
        </VBox>
    </children>
</AnchorPane>
