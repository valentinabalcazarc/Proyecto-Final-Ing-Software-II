<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="700.0" prefWidth="750.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.piedraazul.app_client.controllers.RegisterProfessionalController">
   <children>

      <!-- Header azul -->
      <Pane prefHeight="100.0" prefWidth="750.0" style="-fx-background-color: #6666FF;">
         <children>
            <Label layoutX="37.0" layoutY="35.0" prefWidth="676.0"
                   text="Registrar profesional" textFill="WHITE" textAlignment="CENTER">
               <font><Font name="Cascadia Code Bold" size="24.0"/></font>
            </Label>
         </children>
      </Pane>

      <!-- Cuerpo del formulario -->
      <Pane layoutY="106.0" prefHeight="534.0" prefWidth="750.0" style="-fx-background-color: WHITE;">
         <children>

            <Label layoutX="30.0" layoutY="16.0" text="Ingrese los siguientes datos:">
               <font><Font name="Cascadia Code Regular" size="16.0"/></font>
            </Label>

            <!-- Cédula -->
            <Label layoutX="30.0" layoutY="55.0" text="Número de cédula:">
               <font><Font name="Cascadia Code Regular" size="14.0"/></font>
            </Label>
            <TextField fx:id="txtNumCedula" layoutX="230.0" layoutY="50.0"
                       prefHeight="28.0" prefWidth="180.0"
                       style="-fx-background-color: #E8E8E8;">
               <font><Font name="Cascadia Code Regular" size="13.0"/></font>
            </TextField>
            <Label fx:id="lb_errorID" layoutX="420.0" layoutY="55.0"
                   textFill="RED" visible="false" text="Error">
               <font><Font size="12.0"/></font>
            </Label>

            <!-- Primer nombre -->
            <Label layoutX="30.0" layoutY="98.0" text="Primer nombre:">
               <font><Font name="Cascadia Code Regular" size="14.0"/></font>
            </Label>
            <TextField fx:id="txtFirstName" layoutX="230.0" layoutY="93.0"
                       prefHeight="28.0" prefWidth="180.0"
                       style="-fx-background-color: #E8E8E8;">
               <font><Font name="Cascadia Code Regular" size="13.0"/></font>
            </TextField>
            <Label fx:id="lb_errorFirstName" layoutX="420.0" layoutY="98.0"
                   textFill="RED" visible="false" text="Error">
               <font><Font size="12.0"/></font>
            </Label>

            <!-- Segundo nombre -->
            <Label layoutX="30.0" layoutY="140.0" text="Segundo nombre:">
               <font><Font name="Cascadia Code Regular" size="14.0"/></font>
            </Label>
            <TextField fx:id="txtSecondName" layoutX="230.0" layoutY="135.0"
                       prefHeight="28.0" prefWidth="180.0"
                       style="-fx-background-color: #E8E8E8;">
               <font><Font name="Cascadia Code Regular" size="13.0"/></font>
            </TextField>
            <Label layoutX="420.0" layoutY="140.0" text="(Opcional)" textFill="#A9A9A9">
               <font><Font size="12.0"/></font>
            </Label>
            <Label fx:id="lb_errorSecondName" layoutX="510.0" layoutY="140.0"
                   textFill="RED" visible="false" text="Error">
               <font><Font size="12.0"/></font>
            </Label>

            <!-- Primer apellido -->
            <Label layoutX="30.0" layoutY="182.0" text="Primer apellido:">
               <font><Font name="Cascadia Code Regular" size="14.0"/></font>
            </Label>
            <TextField fx:id="txtFirstLastName" layoutX="230.0" layoutY="177.0"
                       prefHeight="28.0" prefWidth="180.0"
                       style="-fx-background-color: #E8E8E8;">
               <font><Font name="Cascadia Code Regular" size="13.0"/></font>
            </TextField>
            <Label fx:id="lb_errorFirstLastName" layoutX="420.0" layoutY="182.0"
                   textFill="RED" visible="false" text="Error">
               <font><Font size="12.0"/></font>
            </Label>

            <!-- Segundo apellido -->
            <Label layoutX="30.0" layoutY="224.0" text="Segundo apellido:">
               <font><Font name="Cascadia Code Regular" size="14.0"/></font>
            </Label>
            <TextField fx:id="txtSecondLastName" layoutX="230.0" layoutY="219.0"
                       prefHeight="28.0" prefWidth="180.0"
                       style="-fx-background-color: #E8E8E8;">
               <font><Font name="Cascadia Code Regular" size="13.0"/></font>
            </TextField>
            <Label layoutX="420.0" layoutY="224.0" text="(Opcional)" textFill="#A9A9A9">
               <font><Font size="12.0"/></font>
            </Label>
            <Label fx:id="lb_errorSecondLastName" layoutX="510.0" layoutY="224.0"
                   textFill="RED" visible="false" text="Error">
               <font><Font size="12.0"/></font>
            </Label>

            <!-- Teléfono -->
            <Label layoutX="30.0" layoutY="266.0" text="Teléfono:">
               <font><Font name="Cascadia Code Regular" size="14.0"/></font>
            </Label>
            <TextField fx:id="txtPhoneNumber" layoutX="230.0" layoutY="261.0"
                       prefHeight="28.0" prefWidth="180.0"
                       style="-fx-background-color: #E8E8E8;">
               <font><Font name="Cascadia Code Regular" size="13.0"/></font>
            </TextField>
            <Label fx:id="lb_errorPhone" layoutX="420.0" layoutY="266.0"
                   textFill="RED" visible="false" text="Error">
               <font><Font size="12.0"/></font>
            </Label>

            <!-- Contraseña -->
            <Label layoutX="30.0" layoutY="308.0" text="Contraseña:">
               <font><Font name="Cascadia Code Regular" size="14.0"/></font>
            </Label>
            <PasswordField fx:id="txtPassword" layoutX="230.0" layoutY="303.0"
                           prefHeight="28.0" prefWidth="180.0"
                           style="-fx-background-color: #E8E8E8;">
               <font><Font name="Cascadia Code Regular" size="13.0"/></font>
            </PasswordField>
            <Button fx:id="btnEye" layoutX="418.0" layoutY="303.0"
                    prefHeight="28.0" prefWidth="36.0" text="(-)"
                    onAction="#handleTogglePassword"
                    style="-fx-background-color: #CCCCCC; -fx-cursor: hand;"/>
            <Label fx:id="lb_errorPassword" layoutX="460.0" layoutY="308.0"
                   textFill="RED" visible="false" text="Error">
               <font><Font size="12.0"/></font>
            </Label>

            <!-- Confirmar contraseña -->
            <Label layoutX="30.0" layoutY="350.0" text="Confirmar contraseña:">
               <font><Font name="Cascadia Code Regular" size="14.0"/></font>
            </Label>
            <PasswordField fx:id="txtConPassword" layoutX="230.0" layoutY="345.0"
                           prefHeight="28.0" prefWidth="180.0"
                           style="-fx-background-color: #E8E8E8;">
               <font><Font name="Cascadia Code Regular" size="13.0"/></font>
            </PasswordField>

            <!-- Tipo de profesional -->
            <Label layoutX="30.0" layoutY="392.0" text="Tipo de profesional:">
               <font><Font name="Cascadia Code Regular" size="14.0"/></font>
            </Label>
            <ComboBox fx:id="cbxTipoProf" layoutX="230.0" layoutY="387.0"
                      prefHeight="28.0" prefWidth="180.0"/>

            <!-- Especialidad -->
            <Label layoutX="30.0" layoutY="434.0" text="Especialidad:">
               <font><Font name="Cascadia Code Regular" size="14.0"/></font>
            </Label>
            <ComboBox fx:id="cbxEspecialidad" layoutX="230.0" layoutY="429.0"
                      prefHeight="28.0" prefWidth="180.0"/>

            <!-- Pregunta de seguridad -->
            <Label layoutX="30.0" layoutY="476.0" text="Pregunta de seguridad:">
               <font><Font name="Cascadia Code Regular" size="14.0"/></font>
            </Label>
            <ComboBox fx:id="cbxSecurityQuestion" layoutX="230.0" layoutY="471.0"
                      prefHeight="28.0" prefWidth="340.0"/>

            <!-- Respuesta de seguridad -->
            <Label layoutX="30.0" layoutY="516.0" text="Respuesta:">
               <font><Font name="Cascadia Code Regular" size="14.0"/></font>
            </Label>
            <TextField fx:id="txtSecurityAnswer" layoutX="230.0" layoutY="511.0"
                       prefHeight="28.0" prefWidth="340.0"
                       style="-fx-background-color: #E8E8E8;">
               <font><Font name="Cascadia Code Regular" size="13.0"/></font>
            </TextField>

         </children>
      </Pane>

      <!-- Panel botones inferiores -->
      <Pane layoutY="645.0" prefHeight="55.0" prefWidth="750.0"
            style="-fx-background-color: #F5F5F5;">
         <children>
            <Button fx:id="btnRegresar" layoutX="30.0" layoutY="10.0"
                    prefHeight="35.0" prefWidth="120.0"
                    text="← Regresar"
                    onAction="#handleRegresar"
                    style="-fx-background-color: #AAAAAA; -fx-text-fill: WHITE; -fx-cursor: hand;">
               <font><Font name="Cascadia Code Regular" size="13.0"/></font>
            </Button>

            <Button fx:id="btnCancel" layoutX="480.0" layoutY="10.0"
                    prefHeight="35.0" prefWidth="110.0"
                    text="CANCELAR"
                    onAction="#handleCancel"
                    style="-fx-background-color: #AAAAAA; -fx-text-fill: WHITE; -fx-cursor: hand;">
               <font><Font name="Cascadia Code Regular" size="13.0"/></font>
            </Button>

            <Button fx:id="btnSave" layoutX="607.0" layoutY="10.0"
                    prefHeight="35.0" prefWidth="110.0"
                    text="GUARDAR"
                    onAction="#handleSave"
                    style="-fx-background-color: #6666FF; -fx-text-fill: WHITE; -fx-cursor: hand;">
               <font><Font name="Cascadia Code Regular" size="13.0"/></font>
            </Button>
         </children>
      </Pane>

   </children>
</AnchorPane>
