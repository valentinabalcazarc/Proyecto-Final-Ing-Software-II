<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="760.0"
            prefWidth="930.0"
            styleClass="page--gray"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.piedraazul.app_client.controllers.RegisterProfessionalController">

   <children>

      <ScrollPane fitToWidth="true"
                  hbarPolicy="NEVER"
                  vbarPolicy="AS_NEEDED"
                  style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
                  AnchorPane.bottomAnchor="0.0"
                  AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0"
                  AnchorPane.topAnchor="0.0">

         <content>

            <VBox spacing="12.0" fillWidth="true">

               <padding>
                  <Insets bottom="15.0"
                          left="40.0"
                          right="40.0"
                          top="15.0" />
               </padding>

               <children>

                  <!-- Header -->
                  <VBox alignment="CENTER"
                        spacing="3.0"
                        styleClass="header--patient-gradient">

                     <children>

                        <Label text="PIEDRA AZUL" textFill="WHITE">
                           <font>
                              <Font name="System Bold" size="24.0" />
                           </font>
                        </Label>

                        <Label text="Registrar profesional" textFill="#d0d0ff">
                           <font>
                              <Font size="14.0" />
                           </font>
                        </Label>

                     </children>

                     <padding>
                        <Insets bottom="12.0" top="12.0" />
                     </padding>

                  </VBox>

                  <!-- Título sección: Datos personales -->
                  <VBox spacing="2.0">
                     <children>
                        <Label text="👤  Datos personales"
                               styleClass="form-section-title" />
                        <Label text="Los campos marcados con * son obligatorios"
                               styleClass="form-section-subtitle" />
                     </children>
                  </VBox>

                  <!-- Formulario: Datos personales -->
                  <GridPane hgap="15.0"
                            vgap="8.0"
                            styleClass="card--form">

                     <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                     </columnConstraints>

                     <rowConstraints>
                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />
                     </rowConstraints>

                     <children>

                        <!-- Primer nombre -->
                        <VBox spacing="4.0">
                           <children>
                              <Label text="Primer nombre *" styleClass="specific-app__field-label">
                                 <font><Font name="System Bold" size="11.0" /></font>
                              </Label>
                              <TextField fx:id="txtFirstName" prefHeight="34.0" maxWidth="Infinity"
                                         promptText="Ej: Juan" styleClass="textfield--styled" />
                              <Label fx:id="lb_errorFirstName" text="" styleClass="form-error-label" visible="false" />
                           </children>
                        </VBox>

                        <!-- Primer apellido -->
                        <VBox spacing="4.0" GridPane.columnIndex="1">
                           <children>
                              <Label text="Primer apellido *" styleClass="specific-app__field-label">
                                 <font><Font name="System Bold" size="11.0" /></font>
                              </Label>
                              <TextField fx:id="txtFirstLastName" prefHeight="34.0" maxWidth="Infinity"
                                         promptText="Ej: Pérez" styleClass="textfield--styled" />
                              <Label fx:id="lb_errorFirstLastName" text="" styleClass="form-error-label" visible="false" />
                           </children>
                        </VBox>

                        <!-- Segundo nombre -->
                        <VBox spacing="4.0" GridPane.rowIndex="1">
                           <children>
                              <HBox spacing="5.0" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Segundo nombre" styleClass="specific-app__field-label">
                                       <font><Font name="System Bold" size="11.0" /></font>
                                    </Label>
                                    <Label text="(opcional)" styleClass="form-optional-tag" />
                                 </children>
                              </HBox>
                              <TextField fx:id="txtSecondName" prefHeight="34.0" maxWidth="Infinity"
                                         promptText="Ej: Carlos" styleClass="textfield--styled" />
                              <Label fx:id="lb_errorSecondName" text="" styleClass="form-error-label" visible="false" />
                           </children>
                        </VBox>

                        <!-- Segundo apellido -->
                        <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                           <children>
                              <HBox spacing="5.0" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Segundo apellido" styleClass="specific-app__field-label">
                                       <font><Font name="System Bold" size="11.0" /></font>
                                    </Label>
                                    <Label text="(opcional)" styleClass="form-optional-tag" />
                                 </children>
                              </HBox>
                              <TextField fx:id="txtSecondLastName" prefHeight="34.0" maxWidth="Infinity"
                                         promptText="Ej: García" styleClass="textfield--styled" />
                              <Label fx:id="lb_errorSecondLastName" text="" styleClass="form-error-label" visible="false" />
                           </children>
                        </VBox>

                        <!-- Número de cédula -->
                        <VBox spacing="4.0" GridPane.rowIndex="2">
                           <children>
                              <Label text="Número de cédula *" styleClass="specific-app__field-label">
                                 <font><Font name="System Bold" size="11.0" /></font>
                              </Label>
                              <TextField fx:id="txtNumCedula" prefHeight="34.0" maxWidth="Infinity"
                                         promptText="Ej: 1234567890" styleClass="textfield--styled" />
                              <Label fx:id="lb_errorID" text="" styleClass="form-error-label" visible="false" />
                           </children>
                        </VBox>

                        <!-- Teléfono -->
                        <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                           <children>
                              <Label text="Teléfono *" styleClass="specific-app__field-label">
                                 <font><Font name="System Bold" size="11.0" /></font>
                              </Label>
                              <TextField fx:id="txtPhoneNumber" prefHeight="34.0" maxWidth="Infinity"
                                         promptText="Ej: 3001234567" styleClass="textfield--styled" />
                              <Label fx:id="lb_errorPhone" text="" styleClass="form-error-label" visible="false" />
                           </children>
                        </VBox>

                        <!-- Contraseña -->
                        <VBox spacing="4.0" GridPane.rowIndex="3">
                           <children>
                              <Label text="Contraseña *" styleClass="specific-app__field-label">
                                 <font><Font name="System Bold" size="11.0" /></font>
                              </Label>
                              <HBox spacing="5.0" alignment="CENTER_LEFT">
                                 <children>
                                    <PasswordField fx:id="txtPassword" prefHeight="34.0"
                                                   promptText="Mínimo 6 caracteres"
                                                   styleClass="textfield--styled" HBox.hgrow="ALWAYS" />
                                    <TextField fx:id="txtShowPassword" prefHeight="34.0"
                                               promptText="Mínimo 6 caracteres"
                                               styleClass="textfield--styled" HBox.hgrow="ALWAYS"
                                               visible="false" managed="false" />
                                    <Button fx:id="btnEye" prefHeight="30.0" prefWidth="30.0"
                                            text="👁" onAction="#handleTogglePassword"
                                            styleClass="btn--eye-toggle">
                                       <tooltip><Tooltip text="Mostrar/ocultar contraseña" /></tooltip>
                                    </Button>
                                 </children>
                              </HBox>
                              <Label text="Requiere mayúscula, número y carácter especial"
                                     styleClass="form-field-hint" />
                              <Label fx:id="lb_errorPassword" text="" styleClass="form-error-label" visible="false" />
                           </children>
                        </VBox>

                        <!-- Confirmar contraseña -->
                        <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
                           <children>
                              <Label text="Confirmar contraseña *" styleClass="specific-app__field-label">
                                 <font><Font name="System Bold" size="11.0" /></font>
                              </Label>
                              <PasswordField fx:id="txtConPassword" prefHeight="34.0" maxWidth="Infinity"
                                             promptText="Repita su contraseña" styleClass="textfield--styled" />
                              <TextField fx:id="txtShowConPassword" prefHeight="34.0" maxWidth="Infinity"
                                         promptText="Repita su contraseña" styleClass="textfield--styled"
                                         visible="false" managed="false" />
                           </children>
                        </VBox>

                        <!-- Tipo de profesional -->
                        <VBox spacing="4.0" GridPane.rowIndex="4">
                           <children>
                              <Label text="Tipo de profesional *" styleClass="specific-app__field-label">
                                 <font><Font name="System Bold" size="11.0" /></font>
                              </Label>
                              <ComboBox fx:id="cbxTipoProf" prefHeight="34.0" maxWidth="Infinity"
                                        promptText="Seleccione tipo" styleClass="combobox--styled" />
                           </children>
                        </VBox>

                        <!-- Especialidad -->
                        <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="4">
                           <children>
                              <Label text="Especialidad *" styleClass="specific-app__field-label">
                                 <font><Font name="System Bold" size="11.0" /></font>
                              </Label>
                              <ComboBox fx:id="cbxEspecialidad" prefHeight="34.0" maxWidth="Infinity"
                                        promptText="Seleccione especialidad" styleClass="combobox--styled" />
                           </children>
                        </VBox>

                        <!-- Género -->
                        <VBox spacing="4.0" GridPane.rowIndex="5">
                           <children>
                              <Label text="Género" styleClass="specific-app__field-label">
                                 <font><Font name="System Bold" size="11.0" /></font>
                              </Label>
                              <ComboBox fx:id="cbxGenero" prefHeight="34.0" maxWidth="Infinity"
                                        promptText="Seleccione género" styleClass="combobox--styled" />
                           </children>
                        </VBox>

                     </children>

                  </GridPane>

                  <!-- Título sección: Seguridad y horarios -->
                  <VBox spacing="2.0">
                     <children>
                        <Label text="🔒  Seguridad y horarios" styleClass="form-section-title" />
                        <Label text="Configure la pregunta de seguridad y los horarios de atención"
                               styleClass="form-section-subtitle" />
                     </children>
                  </VBox>

                  <!-- Seguridad y horarios -->
                  <GridPane hgap="15.0" vgap="8.0" styleClass="card--form">

                     <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                     </columnConstraints>

                     <rowConstraints>
                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />
                     </rowConstraints>

                     <children>

                        <!-- Pregunta de seguridad -->
                        <VBox spacing="4.0" GridPane.columnSpan="2">
                           <children>
                              <Label text="Pregunta de seguridad *" styleClass="specific-app__field-label">
                                 <font><Font name="System Bold" size="11.0" /></font>
                              </Label>
                              <ComboBox fx:id="cbxSecurityQuestion" prefHeight="34.0" maxWidth="Infinity"
                                        promptText="Seleccione una pregunta" styleClass="combobox--styled" />
                           </children>
                        </VBox>

                        <!-- Respuesta de seguridad -->
                        <VBox spacing="4.0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                           <children>
                              <Label text="Respuesta *" styleClass="specific-app__field-label">
                                 <font><Font name="System Bold" size="11.0" /></font>
                              </Label>
                              <TextField fx:id="txtSecurityAnswer" prefHeight="34.0" maxWidth="Infinity"
                                         promptText="Escriba su respuesta" styleClass="textfield--styled" />
                           </children>
                        </VBox>

                        <!-- Hora llegada -->
                        <VBox spacing="4.0" GridPane.rowIndex="2">
                           <children>
                              <Label text="Hora llegada *" styleClass="specific-app__field-label">
                                 <font><Font name="System Bold" size="11.0" /></font>
                              </Label>
                              <TextField fx:id="txtArrivalTime" prefHeight="34.0" maxWidth="Infinity"
                                         promptText="HH:mm" styleClass="textfield--styled" />
                              <Label text="Formato 24h, ej: 08:00" styleClass="form-field-hint" />
                           </children>
                        </VBox>

                        <!-- Hora salida -->
                        <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                           <children>
                              <Label text="Hora salida *" styleClass="specific-app__field-label">
                                 <font><Font name="System Bold" size="11.0" /></font>
                              </Label>
                              <TextField fx:id="txtDepartureTime" prefHeight="34.0" maxWidth="Infinity"
                                         promptText="HH:mm" styleClass="textfield--styled" />
                              <Label text="Formato 24h, ej: 17:00" styleClass="form-field-hint" />
                           </children>
                        </VBox>

                        <!-- Intervalo de atención -->
                        <VBox spacing="4.0" GridPane.rowIndex="3">
                           <children>
                              <Label text="Intervalo (min) *" styleClass="specific-app__field-label">
                                 <font><Font name="System Bold" size="11.0" /></font>
                              </Label>
                              <TextField fx:id="txtAttentionInterval" prefHeight="34.0" maxWidth="Infinity"
                                         promptText="Ej: 30" styleClass="textfield--styled" />
                              <Label text="Tiempo en minutos entre citas" styleClass="form-field-hint" />
                           </children>
                        </VBox>

                        <!-- Error horario -->
                        <VBox spacing="4.0" alignment="CENTER_LEFT"
                              GridPane.columnIndex="1" GridPane.rowIndex="3">
                           <children>
                              <Label fx:id="lb_errorSchedule" text="" styleClass="form-error-label" visible="false" />
                           </children>
                        </VBox>

                     </children>

                  </GridPane>

                  <!-- ================================================ -->
                  <!-- Título sección: Días no laborables               -->
                  <!-- ================================================ -->
                  <VBox spacing="2.0">
                     <children>
                        <Label text="📅  Días no laborables" styleClass="form-section-title" />
                        <Label text="Agrega las fechas en las que el profesional NO estará disponible (opcional)"
                               styleClass="form-section-subtitle" />
                     </children>
                  </VBox>

                  <!-- Card días no laborables -->
                  <VBox spacing="10.0" styleClass="card--form">

                     <children>

                        <!-- Fila de checkboxes: Lunes a Viernes -->
                        <HBox spacing="15.0" alignment="CENTER_LEFT"
                              style="-fx-padding: 10 10 10 10;">
                           <children>
                              <CheckBox fx:id="chkMonday" text="Lunes" style="-fx-text-fill: #555577;" />
                              <CheckBox fx:id="chkTuesday" text="Martes" style="-fx-text-fill: #555577;" />
                              <CheckBox fx:id="chkWednesday" text="Miércoles" style="-fx-text-fill: #555577;" />
                              <CheckBox fx:id="chkThursday" text="Jueves" style="-fx-text-fill: #555577;" />
                              <CheckBox fx:id="chkFriday" text="Viernes" style="-fx-text-fill: #555577;" />
                           </children>
                        </HBox>

                     </children>

                  </VBox>

                  <!-- Botones -->
                  <HBox alignment="CENTER" spacing="20.0">

                     <children>

                        <Button fx:id="btnRegresar"
                                mnemonicParsing="false"
                                onAction="#handleRegresar"
                                prefHeight="40.0"
                                prefWidth="150.0"
                                styleClass="btn--patient-outline"
                                text="← Regresar" />

                        <AnchorPane HBox.hgrow="ALWAYS" />

                        <Button fx:id="btnCancel"
                                mnemonicParsing="false"
                                onAction="#handleCancel"
                                prefHeight="40.0"
                                prefWidth="150.0"
                                styleClass="btn--light"
                                text="CANCELAR" />

                        <Button fx:id="btnSave"
                                mnemonicParsing="false"
                                onAction="#handleSave"
                                prefHeight="40.0"
                                prefWidth="150.0"
                                styleClass="btn--success-shadow"
                                text="GUARDAR" />

                     </children>

                  </HBox>

               </children>

            </VBox>

         </content>

      </ScrollPane>

   </children>

</AnchorPane>
