<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="760.0"
            prefWidth="930.0"
            styleClass="page--gray"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.piedraazul.app_client.controllers.RegisterProfessionalController">

   <children>

      <ScrollPane fitToWidth="true"
                  hbarPolicy="NEVER"
                  vbarPolicy="AS_NEEDED"
                  style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
                  AnchorPane.bottomAnchor="0.0"
                  AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0"
                  AnchorPane.topAnchor="0.0">

         <content>

            <VBox spacing="12.0" fillWidth="true">

               <padding>
                  <Insets bottom="15.0"
                          left="40.0"
                          right="40.0"
                          top="15.0" />
               </padding>

               <children>

                  <!-- Header -->
                  <VBox alignment="CENTER"
                        spacing="3.0"
                        styleClass="header--patient-gradient">

                     <children>

                        <Label text="PIEDRA AZUL" textFill="WHITE">
                           <font>
                              <Font name="System Bold" size="24.0" />
                           </font>
                        </Label>

                        <Label text="Registrar profesional" textFill="#d0d0ff">
                           <font>
                              <Font size="14.0" />
                           </font>
                        </Label>

                     </children>

                     <padding>
                        <Insets bottom="12.0" top="12.0" />
                     </padding>

                  </VBox>

                  <!-- Formulario: Datos personales -->
                  <GridPane hgap="15.0"
                            vgap="8.0"
                            styleClass="card--form">

                     <columnConstraints>

                        <ColumnConstraints hgrow="SOMETIMES"
                                           minWidth="10.0"
                                           prefWidth="100.0" />

                        <ColumnConstraints hgrow="SOMETIMES"
                                           minWidth="10.0"
                                           prefWidth="100.0" />

                     </columnConstraints>

                     <rowConstraints>

                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />

                     </rowConstraints>

                     <children>

                        <!-- Primer nombre -->
                        <VBox spacing="4.0">

                           <children>

                              <Label text="Primer nombre *"
                                     styleClass="specific-app__field-label">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>

                              <TextField fx:id="txtFirstName"
                                         prefHeight="34.0"
                                         styleClass="textfield--styled" />

                              <Label fx:id="lb_errorFirstName" text="Error" textFill="RED"
                                     visible="false">
                                 <font><Font size="10.0" /></font>
                              </Label>

                           </children>

                        </VBox>

                        <!-- Primer apellido -->
                        <VBox spacing="4.0"
                              GridPane.columnIndex="1">

                           <children>

                              <Label text="Primer apellido *"
                                     styleClass="specific-app__field-label">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>

                              <TextField fx:id="txtFirstLastName"
                                         prefHeight="34.0"
                                         styleClass="textfield--styled" />

                              <Label fx:id="lb_errorFirstLastName" text="Error" textFill="RED"
                                     visible="false">
                                 <font><Font size="10.0" /></font>
                              </Label>

                           </children>

                        </VBox>

                        <!-- Segundo nombre -->
                        <VBox spacing="4.0"
                              GridPane.rowIndex="1">

                           <children>

                              <Label text="Segundo nombre"
                                     styleClass="specific-app__field-label">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>

                              <TextField fx:id="txtSecondName"
                                         prefHeight="34.0"
                                         styleClass="textfield--styled" />

                              <Label fx:id="lb_errorSecondName" text="Error" textFill="RED"
                                     visible="false">
                                 <font><Font size="10.0" /></font>
                              </Label>

                           </children>

                        </VBox>

                        <!-- Segundo apellido -->
                        <VBox spacing="4.0"
                              GridPane.columnIndex="1"
                              GridPane.rowIndex="1">

                           <children>

                              <Label text="Segundo apellido"
                                     styleClass="specific-app__field-label">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>

                              <TextField fx:id="txtSecondLastName"
                                         prefHeight="34.0"
                                         styleClass="textfield--styled" />

                              <Label fx:id="lb_errorSecondLastName" text="Error" textFill="RED"
                                     visible="false">
                                 <font><Font size="10.0" /></font>
                              </Label>

                           </children>

                        </VBox>

                        <!-- Número de cédula -->
                        <VBox spacing="4.0"
                              GridPane.rowIndex="2">

                           <children>

                              <Label text="Número de cédula *"
                                     styleClass="specific-app__field-label">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>

                              <TextField fx:id="txtNumCedula"
                                         prefHeight="34.0"
                                         styleClass="textfield--styled" />

                              <Label fx:id="lb_errorID" text="Error" textFill="RED"
                                     visible="false">
                                 <font><Font size="10.0" /></font>
                              </Label>

                           </children>

                        </VBox>

                        <!-- Teléfono -->
                        <VBox spacing="4.0"
                              GridPane.columnIndex="1"
                              GridPane.rowIndex="2">

                           <children>

                              <Label text="Teléfono *"
                                     styleClass="specific-app__field-label">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>

                              <TextField fx:id="txtPhoneNumber"
                                         prefHeight="34.0"
                                         styleClass="textfield--styled" />

                              <Label fx:id="lb_errorPhone" text="Error" textFill="RED"
                                     visible="false">
                                 <font><Font size="10.0" /></font>
                              </Label>

                           </children>

                        </VBox>

                        <!-- Contraseña -->
                        <VBox spacing="4.0"
                              GridPane.rowIndex="3">

                           <children>

                              <Label text="Contraseña *"
                                     styleClass="specific-app__field-label">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>

                              <HBox spacing="5.0" alignment="CENTER_LEFT">
                                 <children>
                                    <PasswordField fx:id="txtPassword"
                                                   prefHeight="34.0"
                                                   styleClass="textfield--styled"
                                                   HBox.hgrow="ALWAYS" />

                                    <Button fx:id="btnEye" prefHeight="30.0" prefWidth="30.0"
                                            text="(-)" onAction="#handleTogglePassword"
                                            styleClass="btn--eye-toggle" />
                                 </children>
                              </HBox>

                              <Label fx:id="lb_errorPassword" text="Error" textFill="RED"
                                     visible="false">
                                 <font><Font size="10.0" /></font>
                              </Label>

                           </children>

                        </VBox>

                        <!-- Confirmar contraseña -->
                        <VBox spacing="4.0"
                              GridPane.columnIndex="1"
                              GridPane.rowIndex="3">

                           <children>

                              <Label text="Confirmar contraseña *"
                                     styleClass="specific-app__field-label">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>

                              <PasswordField fx:id="txtConPassword"
                                             prefHeight="34.0"
                                             styleClass="textfield--styled" />

                           </children>

                        </VBox>

                        <!-- Tipo de profesional -->
                        <VBox spacing="4.0"
                              GridPane.rowIndex="4">

                           <children>

                              <Label text="Tipo de profesional *"
                                     styleClass="specific-app__field-label">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>

                              <ComboBox fx:id="cbxTipoProf"
                                        prefHeight="34.0"
                                        prefWidth="320.0"
                                        styleClass="combobox--styled" />

                           </children>

                        </VBox>

                        <!-- Especialidad -->
                        <VBox spacing="4.0"
                              GridPane.columnIndex="1"
                              GridPane.rowIndex="4">

                           <children>

                              <Label text="Especialidad *"
                                     styleClass="specific-app__field-label">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>

                              <ComboBox fx:id="cbxEspecialidad"
                                        prefHeight="34.0"
                                        prefWidth="320.0"
                                        styleClass="combobox--styled" />

                           </children>

                        </VBox>

                        <!-- Género -->
                        <VBox spacing="4.0"
                              GridPane.rowIndex="5">

                           <children>

                              <Label text="Género"
                                     styleClass="specific-app__field-label">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>

                              <ComboBox fx:id="cbxGenero"
                                        prefHeight="34.0"
                                        prefWidth="320.0"
                                        styleClass="combobox--styled" />

                           </children>

                        </VBox>

                     </children>

                  </GridPane>

                  <!-- Seguridad y horarios -->
                  <GridPane hgap="15.0"
                            vgap="8.0"
                            styleClass="card--form">

                     <columnConstraints>

                        <ColumnConstraints hgrow="SOMETIMES"
                                           minWidth="10.0"
                                           prefWidth="100.0" />

                        <ColumnConstraints hgrow="SOMETIMES"
                                           minWidth="10.0"
                                           prefWidth="100.0" />

                     </columnConstraints>

                     <rowConstraints>

                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />

                     </rowConstraints>

                     <children>

                        <!-- Pregunta de seguridad (ancho completo) -->
                        <VBox spacing="4.0"
                              GridPane.columnSpan="2">

                           <children>

                              <Label text="Pregunta de seguridad *"
                                     styleClass="specific-app__field-label">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>

                              <ComboBox fx:id="cbxSecurityQuestion"
                                        prefHeight="34.0"
                                        maxWidth="Infinity"
                                        styleClass="combobox--styled" />

                           </children>

                        </VBox>

                        <!-- Respuesta de seguridad (ancho completo) -->
                        <VBox spacing="4.0"
                              GridPane.rowIndex="1"
                              GridPane.columnSpan="2">

                           <children>

                              <Label text="Respuesta *"
                                     styleClass="specific-app__field-label">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>

                              <TextField fx:id="txtSecurityAnswer"
                                         prefHeight="34.0"
                                         styleClass="textfield--styled" />

                           </children>

                        </VBox>

                        <!-- Hora llegada -->
                        <VBox spacing="4.0"
                              GridPane.rowIndex="2">

                           <children>

                              <Label text="Hora llegada *"
                                     styleClass="specific-app__field-label">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>

                              <TextField fx:id="txtArrivalTime"
                                         prefHeight="34.0"
                                         promptText="HH:mm"
                                         styleClass="textfield--styled" />

                           </children>

                        </VBox>

                        <!-- Hora salida -->
                        <VBox spacing="4.0"
                              GridPane.columnIndex="1"
                              GridPane.rowIndex="2">

                           <children>

                              <Label text="Hora salida *"
                                     styleClass="specific-app__field-label">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>

                              <TextField fx:id="txtDepartureTime"
                                         prefHeight="34.0"
                                         promptText="HH:mm"
                                         styleClass="textfield--styled" />

                           </children>

                        </VBox>

                        <!-- Intervalo de atención -->
                        <VBox spacing="4.0"
                              GridPane.rowIndex="3">

                           <children>

                              <Label text="Intervalo (min) *"
                                     styleClass="specific-app__field-label">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>

                              <TextField fx:id="txtAttentionInterval"
                                         prefHeight="34.0"
                                         promptText="Ej: 30"
                                         styleClass="textfield--styled" />

                           </children>

                        </VBox>

                        <!-- Error horario -->
                        <VBox spacing="4.0"
                              alignment="CENTER_LEFT"
                              GridPane.columnIndex="1"
                              GridPane.rowIndex="3">

                           <children>
                              <Label fx:id="lb_errorSchedule" text="Error" textFill="RED"
                                     visible="false">
                                 <font><Font size="10.0" /></font>
                              </Label>
                           </children>

                        </VBox>

                     </children>

                  </GridPane>

                  <!-- Botones -->
                  <HBox alignment="CENTER"
                        spacing="20.0">

                     <children>

                        <Button fx:id="btnRegresar"
                                mnemonicParsing="false"
                                onAction="#handleRegresar"
                                prefHeight="40.0"
                                prefWidth="150.0"
                                styleClass="btn--patient-outline"
                                text="← Regresar" />

                        <AnchorPane HBox.hgrow="ALWAYS" />

                        <Button fx:id="btnCancel"
                                mnemonicParsing="false"
                                onAction="#handleCancel"
                                prefHeight="40.0"
                                prefWidth="150.0"
                                styleClass="btn--light"
                                text="CANCELAR" />

                        <Button fx:id="btnSave"
                                mnemonicParsing="false"
                                onAction="#handleSave"
                                prefHeight="40.0"
                                prefWidth="150.0"
                                styleClass="btn--success-shadow"
                                text="GUARDAR" />

                     </children>

                  </HBox>

               </children>

            </VBox>

         </content>

      </ScrollPane>

   </children>

</AnchorPane>
