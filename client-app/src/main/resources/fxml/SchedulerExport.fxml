<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" styleClass="page--gradient-light" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.piedraazul.app_client.controllers.SchedulerExportController">
   <children>
      <VBox spacing="18.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>

            <!-- ══ HEADER ══ -->
            <AnchorPane prefHeight="100.0" styleClass="header--patient-gradient">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                     <children>
                        <VBox alignment="CENTER_LEFT" spacing="4.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="EXPORTACIÓN DE CITAS" textFill="WHITE">
                                 <font><Font name="System Bold" size="26.0" /></font>
                              </Label>
                              <Label text="Genera y descarga el reporte de citas por profesional" textFill="#dce0ff">
                                 <font><Font size="13.0" /></font>
                              </Label>
                           </children>
                           <padding><Insets left="30.0" /></padding>
                        </VBox>
                        <Label text="📤" textFill="WHITE">
                           <font><Font size="36.0" /></font>
                           <HBox.margin><Insets right="30.0" /></HBox.margin>
                        </Label>
                     </children>
                  </HBox>
               </children>
            </AnchorPane>

            <!-- ══ FILTROS ══ -->
            <VBox spacing="12.0" styleClass="prof-view-app__filter-card">
               <children>
                  <Label styleClass="prof-view-app__filter-title" text="🔍  Filtros de búsqueda">
                     <font><Font name="System Bold" size="14.0" /></font>
                  </Label>
                  <HBox alignment="CENTER_LEFT" spacing="20.0">
                     <children>
                        <VBox spacing="6.0">
                           <children>
                              <Label styleClass="prof-view-app__field-label" text="Médico / Terapista:">
                                 <font><Font name="System Bold" size="12.0" /></font>
                              </Label>
                              <ComboBox fx:id="cbxProfessional" prefHeight="36.0" prefWidth="260.0" promptText="Seleccione profesional" styleClass="combobox--styled" />
                           </children>
                        </VBox>
                        <VBox spacing="6.0">
                           <children>
                              <Label styleClass="prof-view-app__field-label" text="Fecha de las citas:">
                                 <font><Font name="System Bold" size="12.0" /></font>
                              </Label>
                              <DatePicker fx:id="dpDate" prefHeight="36.0" prefWidth="210.0" styleClass="datepicker--styled" />
                           </children>
                        </VBox>
                        <VBox alignment="BOTTOM_CENTER">
                           <children>
                              <Button mnemonicParsing="false" onAction="#handleFind" prefHeight="36.0" prefWidth="130.0" styleClass="btn--patient-primary" text="🔍  Buscar">
                                 <font><Font name="System Bold" size="13.0" /></font>
                              </Button>
                           </children>
                        </VBox>
                        <VBox alignment="BOTTOM_CENTER">
                           <children>
                              <Button mnemonicParsing="false" onAction="#handleClear" prefHeight="36.0" prefWidth="130.0" styleClass="btn--patient-outline" text="✕  Borrar Filtro">
                                 <font><Font size="13.0" /></font>
                              </Button>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </children>
               <padding><Insets bottom="18.0" left="24.0" right="24.0" top="18.0" /></padding>
               <VBox.margin><Insets left="24.0" right="24.0" /></VBox.margin>
            </VBox>

            <!-- ══ TABLA ══ -->
            <VBox spacing="8.0" VBox.vgrow="ALWAYS">
               <children>
                  <Label styleClass="appointments__section-title" text="Citas encontradas">
                     <font><Font name="System Bold" size="14.0" /></font>
                  </Label>
                  <TableView fx:id="tblAppointments" styleClass="appointments__table" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="colId" prefWidth="80.0" text="ID Cita" />
                        <TableColumn fx:id="colDate" prefWidth="110.0" text="Fecha" />
                        <TableColumn fx:id="colTime" prefWidth="100.0" text="Hora" />
                        <TableColumn fx:id="colPatientName" prefWidth="150.0" text="Paciente" />
                        <TableColumn fx:id="colProfessional" prefWidth="150.0" text="Profesional" />
                        <TableColumn fx:id="colType" prefWidth="100.0" text="Tipo" />
                        <TableColumn fx:id="colSpeciality" prefWidth="120.0" text="Especialidad" />
                        <TableColumn fx:id="colStatus" prefWidth="120.0" text="Estado" />
                        <TableColumn fx:id="colDescription" prefWidth="155.0" text="Descripción" />
                     </columns>
                  </TableView>
               </children>
               <VBox.margin><Insets left="24.0" right="24.0" /></VBox.margin>
            </VBox>

            <!-- ══ FOOTER / ACCIONES ══ -->
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleReturn" prefHeight="42.0" prefWidth="180.0" styleClass="btn--patient-outline" text="← Regresar">
                     <font><Font name="System Bold" size="13.0" /></font>
                  </Button>
                  <AnchorPane HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleExport" prefHeight="42.0" prefWidth="230.0" styleClass="btn--patient-primary" text="📥  Exportar citas...">
                     <font><Font name="System Bold" size="13.0" /></font>
                  </Button>
               </children>
               <padding><Insets bottom="16.0" left="24.0" right="24.0" /></padding>
            </HBox>

         </children>
      </VBox>
   </children>
</AnchorPane>
