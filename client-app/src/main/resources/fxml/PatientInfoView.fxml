<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="760.0"
            prefWidth="930.0"
            styleClass="page--gray"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.piedraazul.app_client.controllers.PatientInfoController">

   <children>

      <ScrollPane fitToWidth="true"
                  hbarPolicy="NEVER"
                  vbarPolicy="AS_NEEDED"
                  style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
                  AnchorPane.bottomAnchor="0.0"
                  AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0"
                  AnchorPane.topAnchor="0.0">

         <content>

            <VBox spacing="12.0" fillWidth="true">

               <padding>
                  <Insets bottom="15.0"
                          left="40.0"
                          right="40.0"
                          top="15.0" />
               </padding>

               <children>

                  <!-- Header -->
                  <VBox alignment="CENTER"
                        spacing="3.0"
                        styleClass="header--patient-gradient">

                     <children>

                        <Label text="AGENDAR CITA AUTOMÁTICA" textFill="WHITE">
                           <font>
                              <Font name="System Bold" size="24.0" />
                           </font>
                        </Label>

                        <Label text="Información del paciente" textFill="#d0d0ff">
                           <font>
                              <Font size="14.0" />
                           </font>
                        </Label>

                     </children>

                     <padding>
                        <Insets bottom="12.0" top="12.0" />
                     </padding>

                  </VBox>

                  <!-- Buscar paciente -->
                  <HBox alignment="CENTER_LEFT"
                        spacing="10.0"
                        styleClass="card--search">

                     <children>

                        <Label text="Ingrese la cédula del paciente:"
                               styleClass="specific-app__field-label">

                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>

                        </Label>

                        <TextField fx:id="txtCedula"
                                   prefHeight="34.0"
                                   prefWidth="230.0"
                                   promptText="Número de identificación"
                                   styleClass="textfield--styled" />

                        <Button mnemonicParsing="false"
                                onAction="#handleBuscar"
                                prefHeight="34.0"
                                prefWidth="90.0"
                                styleClass="btn--patient-primary"
                                text="Buscar" />

                     </children>

                  </HBox>

                  <!-- Error cédula -->
                  <Label fx:id="lblErrorCedula" text="Error" textFill="RED" visible="false">
                     <font><Font size="11.0" /></font>
                  </Label>

                  <!-- Formulario -->
                  <GridPane hgap="15.0"
                            vgap="8.0"
                            styleClass="card--form">

                     <columnConstraints>

                        <ColumnConstraints hgrow="SOMETIMES"
                                           minWidth="10.0"
                                           prefWidth="100.0" />

                        <ColumnConstraints hgrow="SOMETIMES"
                                           minWidth="10.0"
                                           prefWidth="100.0" />

                     </columnConstraints>

                     <rowConstraints>

                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="60.0" />

                     </rowConstraints>

                     <children>

                        <!-- Primer nombre -->
                        <VBox spacing="4.0">

                           <children>

                              <Label text="Primer nombre *"
                                     styleClass="specific-app__field-label">

                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>

                              </Label>

                              <TextField fx:id="txtPrimerNombre"
                                         prefHeight="34.0"
                                         styleClass="textfield--styled" />

                              <Label fx:id="lblErrorPrimerNombre" text="Error" textFill="RED"
                                     visible="false">
                                 <font><Font size="10.0" /></font>
                              </Label>

                           </children>

                        </VBox>

                        <!-- Segundo nombre -->
                        <VBox spacing="4.0"
                              GridPane.columnIndex="1">

                           <children>

                              <Label text="Segundo nombre"
                                     styleClass="specific-app__field-label">

                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>

                              </Label>

                              <TextField fx:id="txtSegundoNombre"
                                         prefHeight="34.0"
                                         styleClass="textfield--styled" />

                              <Label fx:id="lblErrorSegundoNombre" text="Error" textFill="RED"
                                     visible="false">
                                 <font><Font size="10.0" /></font>
                              </Label>

                           </children>

                        </VBox>

                        <!-- Primer apellido -->
                        <VBox spacing="4.0"
                              GridPane.rowIndex="1">

                           <children>

                              <Label text="Primer apellido *"
                                     styleClass="specific-app__field-label">

                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>

                              </Label>

                              <TextField fx:id="txtPrimerApellido"
                                         prefHeight="34.0"
                                         styleClass="textfield--styled" />

                              <Label fx:id="lblErrorPrimerApellido" text="Error" textFill="RED"
                                     visible="false">
                                 <font><Font size="10.0" /></font>
                              </Label>

                           </children>

                        </VBox>

                        <!-- Segundo apellido -->
                        <VBox spacing="4.0"
                              GridPane.columnIndex="1"
                              GridPane.rowIndex="1">

                           <children>

                              <Label text="Segundo apellido"
                                     styleClass="specific-app__field-label">

                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>

                              </Label>

                              <TextField fx:id="txtSegundoApellido"
                                         prefHeight="34.0"
                                         styleClass="textfield--styled" />

                              <Label fx:id="lblErrorSegundoApellido" text="Error" textFill="RED"
                                     visible="false">
                                 <font><Font size="10.0" /></font>
                              </Label>

                           </children>

                        </VBox>

                        <!-- Género -->
                        <VBox spacing="4.0"
                              GridPane.rowIndex="2">

                           <children>

                              <Label text="Género"
                                     styleClass="specific-app__field-label">

                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>

                              </Label>

                              <ComboBox fx:id="cbxGenero"
                                        prefHeight="34.0"
                                        prefWidth="320.0"
                                        styleClass="combobox--styled" />

                           </children>

                        </VBox>

                        <!-- Celular -->
                        <VBox spacing="4.0"
                              GridPane.columnIndex="1"
                              GridPane.rowIndex="2">

                           <children>

                              <Label text="Celular *"
                                     styleClass="specific-app__field-label">

                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>

                              </Label>

                              <TextField fx:id="txtCelular"
                                         prefHeight="34.0"
                                         styleClass="textfield--styled" />

                              <Label fx:id="lblErrorCelular" text="Error" textFill="RED"
                                     visible="false">
                                 <font><Font size="10.0" /></font>
                              </Label>

                           </children>

                        </VBox>

                        <!-- Fecha nacimiento -->
                        <VBox spacing="4.0"
                              GridPane.rowIndex="3">

                           <children>

                              <Label text="Fecha de nacimiento *"
                                     styleClass="specific-app__field-label">

                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>

                              </Label>

                              <DatePicker fx:id="dpFechaNacimiento"
                                          prefHeight="34.0"
                                          prefWidth="320.0"
                                          styleClass="datepicker--styled" />

                              <Label fx:id="lblErrorFecha" text="Error" textFill="RED"
                                     visible="false">
                                 <font><Font size="10.0" /></font>
                              </Label>

                           </children>

                        </VBox>

                        <!-- Edad -->
                        <VBox alignment="CENTER_LEFT"
                              spacing="8.0"
                              GridPane.columnIndex="1"
                              GridPane.rowIndex="3">

                           <children>

                              <HBox alignment="CENTER_LEFT"
                                    spacing="8.0">

                                 <children>

                                    <Label text="Edad:"
                                           styleClass="specific-app__field-label">

                                       <font>
                                          <Font name="System Bold" size="13.0" />
                                       </font>

                                    </Label>

                                    <TextField fx:id="txtEdad"
                                               prefHeight="34.0"
                                               prefWidth="120.0"
                                               styleClass="textfield--styled" />

                                 </children>

                              </HBox>

                           </children>

                        </VBox>

                     </children>

                  </GridPane>

                  <!-- Botones -->
                  <HBox alignment="CENTER"
                        spacing="20.0">

                     <children>

                        <Button mnemonicParsing="false"
                                onAction="#handleRegresar"
                                prefHeight="40.0"
                                prefWidth="170.0"
                                styleClass="btn--patient-outline"
                                text="&lt;- Regresar" />

                        <AnchorPane HBox.hgrow="ALWAYS" />

                        <Button mnemonicParsing="false"
                                onAction="#handleContinuar"
                                prefHeight="40.0"
                                prefWidth="170.0"
                                styleClass="btn--success-shadow"
                                text="Continuar" />

                     </children>

                  </HBox>

               </children>

            </VBox>

         </content>

      </ScrollPane>

   </children>

</AnchorPane>
