<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.piedraazul.app_client.controllers.PatientInfoController">
    <children>

        <!-- ══ HEADER ══ -->
        <AnchorPane prefHeight="100.0" prefWidth="800.0" styleClass="header--blue">
            <children>
                <VBox alignment="CENTER"
                      AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                      AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <Label text="AGENDAR CITA AUTOMÁTICA" textFill="WHITE">
                            <font><Font name="Cascadia Code Bold" size="25.0" /></font>
                        </Label>
                        <Label text="Información del paciente" textFill="WHITE">
                            <font><Font name="Cascadia Code Bold" size="16.0" /></font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </AnchorPane>

        <!-- ══ BODY ══ -->
        <AnchorPane prefHeight="500.0" prefWidth="800.0" styleClass="page--white">
            <children>
                <VBox spacing="20.0"
                      AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="50.0"
                      AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="20.0">
                    <children>

                        <!-- ── Búsqueda por cédula ── -->
                        <VBox spacing="5.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <children>
                                        <Label text="Ingrese la cedula del paciente:">
                                            <font><Font name="Cascadia Code" size="13.0" /></font>
                                        </Label>
                                        <TextField fx:id="txtCedula" prefWidth="200.0" styleClass="textfield--styled" />
                                        <Button mnemonicParsing="false" onAction="#handleBuscar"
                                                prefHeight="30.0" prefWidth="120.0"
                                                styleClass="btn--primary-alt" text="Buscar">
                                            <font><Font name="Cascadia Code" size="14.0" /></font>
                                        </Button>
                                    </children>
                                </HBox>
                                <Label fx:id="lblErrorCedula" text="Error" textFill="RED" visible="false">
                                    <font><Font size="13.0" /></font>
                                    <VBox.margin><Insets left="235.0" /></VBox.margin>
                                </Label>
                            </children>
                        </VBox>

                        <!-- ── Datos del paciente (GridPane unificado 5 columnas) ── -->
                        <!--
                            Col 0 → label izquierdo   (fijo 155px)
                            Col 1 → input izquierdo   (flexible)
                            Col 2 → separador         (fijo 30px)
                            Col 3 → label derecho     (fijo 155px)
                            Col 4 → input derecho     (flexible)
                        -->
                        <GridPane hgap="10.0" vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="NEVER" minWidth="155.0" prefWidth="155.0" />
                                <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" prefWidth="180.0" />
                                <ColumnConstraints hgrow="NEVER" minWidth="30.0"  prefWidth="30.0"  />
                                <ColumnConstraints hgrow="NEVER" minWidth="155.0" prefWidth="155.0" />
                                <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" prefWidth="180.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <!-- Fila 0: primer nombre / primer apellido -->
                                <RowConstraints minHeight="32.0" prefHeight="32.0" vgrow="NEVER" />
                                <!-- Fila 1: errores nombre / apellido -->
                                <RowConstraints minHeight="16.0" prefHeight="16.0" vgrow="NEVER" />
                                <!-- Fila 2: segundo nombre / segundo apellido (con sub-label opcional) -->
                                <RowConstraints minHeight="44.0" prefHeight="44.0" vgrow="NEVER" />
                                <!-- Fila 3: errores segundo nombre / apellido -->
                                <RowConstraints minHeight="16.0" prefHeight="16.0" vgrow="NEVER" />
                                <!-- Fila 4: género / celular -->
                                <RowConstraints minHeight="32.0" prefHeight="32.0" vgrow="NEVER" />
                                <!-- Fila 5: error celular -->
                                <RowConstraints minHeight="16.0" prefHeight="16.0" vgrow="NEVER" />
                                <!-- Fila 6: fecha de nacimiento / edad -->
                                <RowConstraints minHeight="32.0" prefHeight="32.0" vgrow="NEVER" />
                                <!-- Fila 7: error fecha -->
                                <RowConstraints minHeight="16.0" prefHeight="16.0" vgrow="NEVER" />
                            </rowConstraints>
                            <children>

                                <!-- Fila 0 ─ Primer nombre | Primer apellido -->
                                <Label text="Primer nombre:"
                                       GridPane.columnIndex="0" GridPane.rowIndex="0"
                                       GridPane.valignment="CENTER">
                                    <font><Font name="Cascadia Code" size="13.0" /></font>
                                </Label>
                                <TextField fx:id="txtPrimerNombre" maxWidth="Infinity"
                                           styleClass="textfield--styled"
                                           GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label text="Primer apellido:"
                                       GridPane.columnIndex="3" GridPane.rowIndex="0"
                                       GridPane.valignment="CENTER">
                                    <font><Font name="Cascadia Code" size="13.0" /></font>
                                </Label>
                                <TextField fx:id="txtPrimerApellido" maxWidth="Infinity"
                                           styleClass="textfield--styled"
                                           GridPane.columnIndex="4" GridPane.rowIndex="0" />

                                <!-- Fila 1 ─ Errores nombre / apellido -->
                                <Label fx:id="lblErrorPrimerNombre" text="Error" textFill="RED"
                                       visible="false"
                                       GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                <Label fx:id="lblErrorPrimerApellido" text="Error" textFill="RED"
                                       visible="false"
                                       GridPane.columnIndex="4" GridPane.rowIndex="1" />

                                <!-- Fila 2 ─ Segundo nombre | Segundo apellido -->
                                <VBox spacing="1.0"
                                      GridPane.columnIndex="0" GridPane.rowIndex="2"
                                      GridPane.valignment="CENTER">
                                    <children>
                                        <Label text="Segundo nombre:">
                                            <font><Font name="Cascadia Code" size="13.0" /></font>
                                        </Label>
                                        <Label text="(Opcional)" textFill="DARKGRAY">
                                            <font><Font size="11.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                                <TextField fx:id="txtSegundoNombre" maxWidth="Infinity"
                                           styleClass="textfield--styled"
                                           GridPane.columnIndex="1" GridPane.rowIndex="2"
                                           GridPane.valignment="CENTER" />

                                <VBox spacing="1.0"
                                      GridPane.columnIndex="3" GridPane.rowIndex="2"
                                      GridPane.valignment="CENTER">
                                    <children>
                                        <Label text="Segundo apellido:">
                                            <font><Font name="Cascadia Code" size="13.0" /></font>
                                        </Label>
                                        <Label text="(Opcional)" textFill="DARKGRAY">
                                            <font><Font size="11.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                                <TextField fx:id="txtSegundoApellido" maxWidth="Infinity"
                                           styleClass="textfield--styled"
                                           GridPane.columnIndex="4" GridPane.rowIndex="2"
                                           GridPane.valignment="CENTER" />

                                <!-- Fila 3 ─ Errores segundo nombre / apellido -->
                                <Label fx:id="lblErrorSegundoNombre" text="Error" textFill="RED"
                                       visible="false"
                                       GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                <Label fx:id="lblErrorSegundoApellido" text="Error" textFill="RED"
                                       visible="false"
                                       GridPane.columnIndex="4" GridPane.rowIndex="3" />

                                <!-- Fila 4 ─ Género | Celular -->
                                <Label text="Género:"
                                       GridPane.columnIndex="0" GridPane.rowIndex="4"
                                       GridPane.valignment="CENTER">
                                    <font><Font name="Cascadia Code" size="13.0" /></font>
                                </Label>
                                <ComboBox fx:id="cbxGenero" maxWidth="Infinity"
                                          styleClass="combobox--styled"
                                          GridPane.columnIndex="1" GridPane.rowIndex="4"
                                          GridPane.valignment="CENTER" />

                                <Label text="Celular:"
                                       GridPane.columnIndex="3" GridPane.rowIndex="4"
                                       GridPane.valignment="CENTER">
                                    <font><Font name="Cascadia Code" size="13.0" /></font>
                                </Label>
                                <TextField fx:id="txtCelular" maxWidth="Infinity"
                                           styleClass="textfield--styled"
                                           GridPane.columnIndex="4" GridPane.rowIndex="4" />

                                <!-- Fila 5 ─ Error celular -->
                                <Label fx:id="lblErrorCelular" text="Error" textFill="RED"
                                       visible="false"
                                       GridPane.columnIndex="4" GridPane.rowIndex="5" />

                                <!-- Fila 6 ─ Fecha de nacimiento | Edad -->
                                <Label text="Fecha de nacimiento:"
                                       GridPane.columnIndex="0" GridPane.rowIndex="6"
                                       GridPane.valignment="CENTER">
                                    <font><Font name="Cascadia Code" size="13.0" /></font>
                                </Label>
                                <DatePicker fx:id="dpFechaNacimiento" maxWidth="Infinity"
                                            styleClass="datepicker--styled"
                                            GridPane.columnIndex="1" GridPane.rowIndex="6"
                                            GridPane.valignment="CENTER" />

                                <Label text="Edad:"
                                       GridPane.columnIndex="3" GridPane.rowIndex="6"
                                       GridPane.valignment="CENTER">
                                    <font><Font name="Cascadia Code" size="13.0" /></font>
                                </Label>
                                <TextField fx:id="txtEdad" maxWidth="Infinity"
                                           styleClass="textfield--styled"
                                           GridPane.columnIndex="4" GridPane.rowIndex="6" />

                                <!-- Fila 7 ─ Error fecha -->
                                <Label fx:id="lblErrorFecha" text="Error" textFill="RED"
                                       visible="false"
                                       GridPane.columnIndex="1" GridPane.rowIndex="7" />

                            </children>
                        </GridPane>

                        <!-- Empuja los botones hacia abajo -->
                        <Pane VBox.vgrow="ALWAYS" />

                        <!-- ── Botones de acción ── -->
                        <HBox alignment="CENTER" spacing="100.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#handleRegresar"
                                        prefHeight="35.0" prefWidth="150.0"
                                        styleClass="btn--secondary" text="&lt;- Regresar">
                                    <font><Font name="Cascadia Code" size="14.0" /></font>
                                </Button>
                                <Button mnemonicParsing="false" onAction="#handleContinuar"
                                        prefHeight="35.0" prefWidth="150.0"
                                        styleClass="btn--success" text="Continuar">
                                    <font><Font name="Cascadia Code" size="14.0" /></font>
                                </Button>
                            </children>
                            <VBox.margin><Insets top="20.0" /></VBox.margin>
                        </HBox>

                    </children>
                </VBox>
            </children>
        </AnchorPane>

    </children>
</VBox>
