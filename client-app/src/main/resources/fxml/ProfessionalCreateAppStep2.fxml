<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="760.0"
            prefWidth="930.0"
            styleClass="page--gray"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.piedraazul.app_client.controllers.ProfessionalCreateAppStep2Controller">

   <children>

      <ScrollPane fitToWidth="true"
                  hbarPolicy="NEVER"
                  vbarPolicy="AS_NEEDED"
                  style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
                  AnchorPane.bottomAnchor="0.0"
                  AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0"
                  AnchorPane.topAnchor="0.0">

         <content>

            <VBox spacing="12.0" fillWidth="true">

               <padding>
                  <Insets bottom="15.0"
                          left="40.0"
                          right="40.0"
                          top="15.0" />
               </padding>

               <children>

                  <!-- Header -->
                  <VBox alignment="CENTER"
                        spacing="3.0"
                        styleClass="header--patient-gradient">

                     <children>

                        <Label text="AGENDAR CITA" textFill="WHITE">
                           <font>
                              <Font name="System Bold" size="24.0" />
                           </font>
                        </Label>

                        <Label text="Paso 2 — Información del paciente" textFill="#d0d0ff">
                           <font>
                              <Font size="14.0" />
                           </font>
                        </Label>

                     </children>

                     <padding>
                        <Insets bottom="12.0" top="12.0" />
                     </padding>

                  </VBox>

                  <!-- Buscar paciente -->
                  <HBox alignment="CENTER_LEFT"
                        spacing="10.0"
                        styleClass="card--search">

                     <children>

                        <Label text="Ingrese la cédula del paciente:"
                               styleClass="specific-app__field-label">

                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>

                        </Label>

                        <TextField fx:id="txtCedula"
                                   prefHeight="34.0"
                                   prefWidth="230.0"
                                   promptText="Número de identificación"
                                   styleClass="textfield--styled" />

                        <Button fx:id="btnFind"
                                mnemonicParsing="false"
                                onAction="#handleFindPatient"
                                prefHeight="34.0"
                                prefWidth="90.0"
                                styleClass="btn--patient-primary"
                                text="Buscar" />

                     </children>

                  </HBox>

                  <!-- Título de sección: Datos del paciente -->
                  <VBox spacing="2.0">
                     <children>
                        <Label text="📋  Datos del paciente"
                               styleClass="form-section-title" />
                        <Label text="Los campos marcados con * son obligatorios"
                               styleClass="form-section-subtitle" />
                     </children>
                  </VBox>

                  <!-- Formulario -->
                  <GridPane hgap="15.0"
                            vgap="8.0"
                            styleClass="card--form">

                     <columnConstraints>

                        <ColumnConstraints hgrow="SOMETIMES"
                                           minWidth="10.0"
                                           prefWidth="100.0" />

                        <ColumnConstraints hgrow="SOMETIMES"
                                           minWidth="10.0"
                                           prefWidth="100.0" />

                     </columnConstraints>

                     <rowConstraints>

                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="50.0" />
                        <RowConstraints minHeight="60.0" />
                        <RowConstraints minHeight="50.0" />

                     </rowConstraints>

                     <children>

                        <!-- Primer nombre -->
                        <VBox spacing="4.0">

                           <children>

                              <Label text="Primer nombre *"
                                     styleClass="specific-app__field-label">

                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>

                              </Label>

                              <TextField fx:id="txtFirstName"
                                         prefHeight="34.0"
                                         maxWidth="Infinity"
                                         promptText="Ej: Juan"
                                         styleClass="textfield--styled" />

                           </children>

                        </VBox>

                        <!-- Segundo nombre -->
                        <VBox spacing="4.0"
                              GridPane.columnIndex="1">

                           <children>

                              <HBox spacing="5.0" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Segundo nombre"
                                           styleClass="specific-app__field-label">
                                       <font>
                                          <Font name="System Bold" size="11.0" />
                                       </font>
                                    </Label>
                                    <Label text="(opcional)" styleClass="form-optional-tag" />
                                 </children>
                              </HBox>

                              <TextField fx:id="txtSecondName"
                                         prefHeight="34.0"
                                         maxWidth="Infinity"
                                         promptText="Ej: Carlos"
                                         styleClass="textfield--styled" />

                           </children>

                        </VBox>

                        <!-- Primer apellido -->
                        <VBox spacing="4.0"
                              GridPane.rowIndex="1">

                           <children>

                              <Label text="Primer apellido *"
                                     styleClass="specific-app__field-label">

                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>

                              </Label>

                              <TextField fx:id="txtFirstLastName"
                                         prefHeight="34.0"
                                         maxWidth="Infinity"
                                         promptText="Ej: Pérez"
                                         styleClass="textfield--styled" />

                           </children>

                        </VBox>

                        <!-- Segundo apellido -->
                        <VBox spacing="4.0"
                              GridPane.columnIndex="1"
                              GridPane.rowIndex="1">

                           <children>

                              <HBox spacing="5.0" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Segundo apellido"
                                           styleClass="specific-app__field-label">
                                       <font>
                                          <Font name="System Bold" size="11.0" />
                                       </font>
                                    </Label>
                                    <Label text="(opcional)" styleClass="form-optional-tag" />
                                 </children>
                              </HBox>

                              <TextField fx:id="txtSecondLastName"
                                         prefHeight="34.0"
                                         maxWidth="Infinity"
                                         promptText="Ej: García"
                                         styleClass="textfield--styled" />

                           </children>

                        </VBox>

                        <!-- Género -->
                        <VBox spacing="4.0"
                              GridPane.rowIndex="2">

                           <children>

                              <Label text="Género"
                                     styleClass="specific-app__field-label">

                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>

                              </Label>

                              <ComboBox fx:id="cbxGender"
                                        prefHeight="34.0"
                                        maxWidth="Infinity"
                                        promptText="Seleccione género"
                                        styleClass="combobox--styled" />

                           </children>

                        </VBox>

                        <!-- Celular -->
                        <VBox spacing="4.0"
                              GridPane.columnIndex="1"
                              GridPane.rowIndex="2">

                           <children>

                              <Label text="Celular *"
                                     styleClass="specific-app__field-label">

                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>

                              </Label>

                              <TextField fx:id="txtPhone"
                                         prefHeight="34.0"
                                         maxWidth="Infinity"
                                         promptText="Ej: 3001234567"
                                         styleClass="textfield--styled" />

                           </children>

                        </VBox>

                        <!-- Fecha nacimiento -->
                        <VBox spacing="4.0"
                              GridPane.rowIndex="3">

                           <children>

                              <Label text="Fecha de nacimiento *"
                                     styleClass="specific-app__field-label">

                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>

                              </Label>

                              <DatePicker fx:id="dpBirthDate"
                                          prefHeight="34.0"
                                          maxWidth="Infinity"
                                          promptText="Seleccione fecha"
                                          styleClass="datepicker--styled" />

                           </children>

                        </VBox>

                        <!-- Edad + Checkboxes -->
                        <VBox alignment="CENTER_LEFT"
                              spacing="8.0"
                              GridPane.columnIndex="1"
                              GridPane.rowIndex="3">

                           <children>

                              <!-- Edad -->
                              <HBox alignment="CENTER_LEFT"
                                    spacing="8.0">

                                 <children>

                                    <Label text="Edad:"
                                           styleClass="specific-app__field-label">

                                       <font>
                                          <Font name="System Bold" size="13.0" />
                                       </font>

                                    </Label>

                                    <Label fx:id="lblAge"
                                           text="0 años"
                                           styleClass="appointments__section-title">

                                       <font>
                                          <Font size="13.0" />
                                       </font>

                                    </Label>

                                 </children>

                              </HBox>

                              <!-- Checkboxes: Tipo de cita -->
                              <Label text="Tipo de cita:"
                                     styleClass="specific-app__field-label">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>

                              <HBox alignment="CENTER_LEFT"
                                    spacing="18.0">

                                 <children>

                                    <!-- Urgente -->
                                    <HBox alignment="CENTER_LEFT"
                                          spacing="5.0">

                                       <children>

                                          <CheckBox fx:id="chkUrgente" />

                                          <Label text="Urgente"
                                                 styleClass="specific-app__field-label">

                                             <font>
                                                <Font size="11.0" />
                                             </font>

                                          </Label>

                                       </children>

                                    </HBox>

                                    <!-- Prioritaria -->
                                    <HBox alignment="CENTER_LEFT"
                                          spacing="5.0">

                                       <children>

                                          <CheckBox fx:id="chkPrioritaria" />

                                          <Label text="Prioritaria"
                                                 styleClass="specific-app__field-label">

                                             <font>
                                                <Font size="11.0" />
                                             </font>

                                          </Label>

                                       </children>

                                    </HBox>

                                    <!-- Cita Control -->
                                    <HBox alignment="CENTER_LEFT"
                                          spacing="5.0">

                                       <children>

                                          <CheckBox fx:id="chkCitaControl" />

                                          <Label text="Cita de Control"
                                                 styleClass="specific-app__field-label">

                                             <font>
                                                <Font size="11.0" />
                                             </font>

                                          </Label>

                                       </children>

                                    </HBox>

                                 </children>

                              </HBox>

                           </children>

                        </VBox>

                        <!-- Fecha y hora de la cita -->
                        <VBox spacing="4.0"
                              GridPane.rowIndex="4"
                              GridPane.columnSpan="2">

                           <children>

                              <Label text="📅  Fecha y hora de la cita"
                                     styleClass="specific-app__field-label">

                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>

                              </Label>

                              <TextField fx:id="txtAppSummary"
                                         editable="false"
                                         prefHeight="34.0"
                                         maxWidth="Infinity"
                                         promptText="Se completará automáticamente"
                                         styleClass="textfield--styled,textfield--readonly" />

                              <Label text="Este campo se completa con la información del paso anterior"
                                     styleClass="form-field-hint" />

                           </children>

                        </VBox>

                     </children>

                  </GridPane>

                  <!-- Título sección: Observación -->
                  <VBox spacing="2.0">
                     <children>
                        <Label text="📝  Observaciones"
                               styleClass="form-section-title" />
                        <Label text="Agregue notas relevantes sobre la cita"
                               styleClass="form-section-subtitle" />
                     </children>
                  </VBox>

                  <!-- Observación -->
                  <VBox spacing="5.0" styleClass="card--form">

                     <children>

                        <Label text="Observación:"
                               styleClass="specific-app__field-label">

                           <font>
                              <Font name="System Bold" size="11.0" />
                           </font>

                        </Label>

                        <TextArea fx:id="txtObservation"
                                  prefHeight="100.0"
                                  promptText="Ingrese notas adicionales aquí... (motivo de consulta, síntomas, etc.)"
                                  styleClass="textarea--styled" />

                     </children>

                  </VBox>

                  <!-- Botones -->
                  <HBox alignment="CENTER"
                        spacing="20.0">

                     <children>

                        <Button fx:id="btnReturn"
                                mnemonicParsing="false"
                                onAction="#handleReturn"
                                prefHeight="40.0"
                                prefWidth="170.0"
                                styleClass="btn--patient-outline"
                                text="← Regresar" />

                        <AnchorPane HBox.hgrow="ALWAYS" />

                        <Button fx:id="btnSave"
                                mnemonicParsing="false"
                                onAction="#handleSave"
                                prefHeight="40.0"
                                prefWidth="170.0"
                                styleClass="btn--success-shadow"
                                text="Guardar cita" />

                     </children>

                  </HBox>

               </children>

            </VBox>

         </content>

      </ScrollPane>

   </children>

</AnchorPane>