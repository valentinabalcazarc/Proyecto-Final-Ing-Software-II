<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="600.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.piedraazul.app_client.controllers.ProfessionalViewAppointmentsController"
            styleClass="page--gradient-professional">
    <children>

        <!-- Header profesional -->
        <Pane prefHeight="100.0" prefWidth="900.0" styleClass="header--professional-gradient">
            <children>
                <Label layoutX="40.0" layoutY="30.0" text="VISUALIZACIÓN DE CITAS" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                </Label>
                <Button fx:id="btnRegresar" layoutX="750.0" layoutY="30.0"
                        mnemonicParsing="false" onAction="#handleRegresar"
                        prefHeight="40.0" prefWidth="120.0"
                        styleClass="btn--ghost-white"
                        text="← Regresar">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
            </children>
        </Pane>

        <!-- Filtros -->
        <Pane layoutX="30.0" layoutY="120.0" prefHeight="120.0" prefWidth="840.0" styleClass="card--rounded">
            <children>
                <HBox layoutX="20.0" layoutY="20.0" spacing="40.0" alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="8.0">
                            <children>
                                <Label text="Profesional:" textFill="#444444">
                                    <font><Font name="System Bold" size="14.0"/></font>
                                </Label>
                                <ComboBox fx:id="cbxProfessional" prefWidth="250.0" promptText="Seleccionar médico..." />
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Label text="Fecha:" textFill="#444444">
                                    <font><Font name="System Bold" size="14.0"/></font>
                                </Label>
                                <DatePicker fx:id="dpDate" prefWidth="180.0" promptText="Seleccionar fecha..." />
                            </children>
                        </VBox>

                        <HBox spacing="15.0" alignment="BOTTOM_LEFT" styleClass="filter-actions">
                            <children>
                                <Button fx:id="btnFind" mnemonicParsing="false" onAction="#handleFind"
                                        prefHeight="35.0" prefWidth="100.0"
                                        styleClass="btn--teal-rounded"
                                        text="Buscar" />
                                <Button fx:id="btnClearFilter" mnemonicParsing="false" onAction="#handleClearFilter"
                                        prefHeight="35.0" prefWidth="120.0"
                                        styleClass="btn--outline-teal-rounded"
                                        text="Borrar Filtro" />
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </children>
        </Pane>

        <!-- Tabla -->
        <Pane layoutX="30.0" layoutY="260.0" prefHeight="310.0" prefWidth="840.0" styleClass="card--rounded">
            <children>
                <TableView fx:id="tblAppointments" layoutX="20.0" layoutY="20.0" prefHeight="270.0" prefWidth="800.0">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="80.0" text="ID Cita" />
                        <TableColumn fx:id="colDate" prefWidth="110.0" text="Fecha" />
                        <TableColumn fx:id="colTime" prefWidth="100.0" text="Hora" />
                        <TableColumn fx:id="colPatientName" text="Paciente" prefWidth="150"/>
                        <TableColumn fx:id="colProfessional" text="Profesional" prefWidth="150"/>
                        <TableColumn fx:id="colType" text="Tipo" prefWidth="100"/>
                        <TableColumn fx:id="colSpeciality" text="Especialidad" prefWidth="120"/>
                        <TableColumn fx:id="colStatus" prefWidth="150.0" text="Estado" />
                        <TableColumn fx:id="colDescription" prefWidth="155.0" text="Descripción" />

                    </columns>
                </TableView>
            </children>
        </Pane>

    </children>
</AnchorPane>
