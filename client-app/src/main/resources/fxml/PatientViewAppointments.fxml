<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="500.0" prefWidth="750.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.piedraazul.app_client.controllers.PatientViewAppointmentsController"
            style="-fx-background-color: linear-gradient(to bottom right, #f8f9fa, #e9ecef);">
    <children>

        <!-- Header azul -->
        <Pane prefHeight="100.0" prefWidth="750.0" style="-fx-background-color: linear-gradient(to right, #4e54c8, #8f94fb); -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 5);">
            <children>
                <Label layoutX="40.0" layoutY="30.0" text="VER MIS CITAS" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                </Label>
                <Button fx:id="btnRegresar" layoutX="600.0" layoutY="30.0"
                        mnemonicParsing="false" onAction="#handleRegresar"
                        prefHeight="40.0" prefWidth="120.0"
                        style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-background-radius: 20; -fx-border-color: white; -fx-border-radius: 20; -fx-cursor: hand;"
                        text="← Regresar">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
            </children>
        </Pane>

        <!-- Contenido -->
        <Pane layoutX="30.0" layoutY="120.0" prefHeight="350.0" prefWidth="690.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
            <children>
                <Label layoutX="20.0" layoutY="20.0" text="CITAS PROGRAMADAS:" textFill="#444444">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>

                <TableView fx:id="tblAppointments" layoutX="20.0" layoutY="60.0" prefHeight="220.0" prefWidth="650.0" style="-fx-background-radius: 5; -fx-border-color: #e0e0e0;">
                    <columns>
                        <TableColumn fx:id="colDate" prefWidth="120.0" text="Fecha" />
                        <TableColumn fx:id="colTime" prefWidth="100.0" text="Hora" />
                        <TableColumn fx:id="colProfessional" prefWidth="230.0" text="Profesional" />
                        <TableColumn fx:id="colStatus" prefWidth="180.0" text="Estado" />
                    </columns>
                </TableView>

                <HBox layoutX="20.0" layoutY="300.0" spacing="20.0">
                    <children>
                        <Button fx:id="btnCancelAppointment" mnemonicParsing="false" onAction="#handleCancelAppointment"
                                prefHeight="35.0" prefWidth="160.0"
                                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;"
                                text="Cancelar Cita" />
                        
                        <Button fx:id="btnReschedule" mnemonicParsing="false" onAction="#handleReschedule"
                                prefHeight="35.0" prefWidth="160.0"
                                style="-fx-background-color: #f1c40f; -fx-text-fill: #2c3e50; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;"
                                text="Reagendar Cita" />
                    </children>
                </HBox>
            </children>
        </Pane>

    </children>
</AnchorPane>
