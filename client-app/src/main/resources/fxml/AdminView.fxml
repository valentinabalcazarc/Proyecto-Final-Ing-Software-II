<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="380.0" prefWidth="580.0"
            styleClass="admin__page"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.piedraazul.app_client.controllers.AdminController">
   <children>

      <!-- Header con gradiente moderno -->
      <Pane prefHeight="115.0" prefWidth="580.0" styleClass="admin__header">
         <children>
            <Label layoutX="0.0" layoutY="24.0" prefWidth="580.0"
                   text="Panel de Administrador"
                   textAlignment="CENTER" styleClass="admin__header-title">
               <font><Font name="Cascadia Code Bold" size="22.0"/></font>
            </Label>
            <Label layoutX="0.0" layoutY="64.0" prefWidth="580.0"
                   text="Gestiona profesionales y horarios del sistema"
                   textAlignment="CENTER" styleClass="admin__header-subtitle">
               <font><Font name="Cascadia Code Regular" size="11.5"/></font>
            </Label>
         </children>
      </Pane>

      <!-- Contenido principal -->
      <Pane layoutY="123.0" prefHeight="257.0" prefWidth="580.0" styleClass="admin__body">
         <children>

            <!-- Card de acciones principales -->
            <Pane layoutX="28.0" layoutY="20.0" prefHeight="148.0" prefWidth="524.0"
                  styleClass="admin__actions-card">
               <children>
                  <Label layoutX="20.0" layoutY="15.0" text="Acciones rápidas"
                         styleClass="admin__card-title">
                     <font><Font name="Cascadia Code Bold" size="13.0"/></font>
                  </Label>

                  <Button fx:id="btnRegProfessional" layoutX="20.0" layoutY="52.0"
                          prefHeight="52.0" prefWidth="224.0"
                          text="Registrar profesional"
                          onAction="#handleRegProfessional"
                          styleClass="admin__btn-action">
                     <font><Font name="Cascadia Code Regular" size="13.0"/></font>
                  </Button>

                  <Button fx:id="btnProfessionalSchedule" layoutX="280.0" layoutY="52.0"
                          prefHeight="52.0" prefWidth="224.0"
                          text="Gestionar horario"
                          onAction="#handleProfessionalSchedule"
                          styleClass="admin__btn-action">
                     <font><Font name="Cascadia Code Regular" size="13.0"/></font>
                  </Button>
               </children>
            </Pane>

            <!-- Botón cerrar sesión -->
            <Button fx:id="btnCerrarSesion" layoutX="202.0" layoutY="192.0"
                    prefHeight="40.0" prefWidth="176.0"
                    text="Cerrar sesión"
                    onAction="#handleCerrarSesion"
                    styleClass="admin__btn-logout">
               <font><Font name="Cascadia Code Regular" size="13.0"/></font>
            </Button>

         </children>
      </Pane>

   </children>
</AnchorPane>
