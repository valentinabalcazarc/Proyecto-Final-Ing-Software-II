<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="950.0" styleClass="page--gray" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.piedraazul.app_client.controllers.ProfessionalCreateAppStep1Controller">
   <children>
      <VBox layoutX="40.0" layoutY="30.0" prefHeight="590.0" prefWidth="870.0" spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="30.0">
         <children>
            <VBox alignment="CENTER" spacing="5.0" styleClass="header--teal">
               <children>
                  <Label text="AGENDAR CITA MANUAL" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="28.0" />
                     </font>
                  </Label>
                  <Label text="Selección de fecha y médico" textFill="#e0e0e0">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
               </children>
               <padding>
                  <Insets bottom="20.0" top="20.0" />
               </padding>
            </VBox>
            
            <HBox alignment="CENTER_LEFT" spacing="30.0" styleClass="card--shadow">
               <children>
                  <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Médico / Terapista" textFill="#555555" />
                        <ComboBox fx:id="cbxProfessional" prefHeight="35.0" prefWidth="300.0" promptText="Seleccione un médico" styleClass="combobox--rounded" />
                     </children>
                  </VBox>
                  <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Fecha de las citas" textFill="#555555" />
                        <DatePicker fx:id="dpDate" prefHeight="35.0" prefWidth="250.0" styleClass="datepicker--rounded" />
                     </children>
                  </VBox>
                  <VBox alignment="BOTTOM_CENTER" spacing="10.0">
                     <children>
                        <HBox spacing="10.0">
                           <children>
                              <Button fx:id="btnFind" mnemonicParsing="false" onAction="#handleFilter" prefHeight="35.0" prefWidth="100.0" styleClass="btn--teal" text="Buscar" />
                              <Button fx:id="btnClearFilter" mnemonicParsing="false" onAction="#handleClearFilter" prefHeight="35.0" prefWidth="100.0" styleClass="btn--light" text="Limpiar" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </HBox>
            
            <VBox spacing="10.0" VBox.vgrow="ALWAYS">
               <children>
                  <Label text="Citas disponibles" textFill="#1a5f7a">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
                  <TableView fx:id="tblAppointments" prefHeight="300.0" prefWidth="200.0" styleClass="table--rounded" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colDate" prefWidth="150.0" text="Fecha" />
                      <TableColumn fx:id="colTime" prefWidth="120.0" text="Hora" />
                       <TableColumn fx:id="colProfID" prefWidth="250.0" text="ID Profesional" />
                        <TableColumn fx:id="colProfName" prefWidth="250.0" text="Nombre Profesional" />
                        <TableColumn fx:id="colProfType" prefWidth="200.0" text="Tipo Profesional" />
                        <TableColumn fx:id="colSpeciality" prefWidth="200.0" text="Especialidad" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>
            
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button fx:id="btnRegresar" mnemonicParsing="false" onAction="#handleRegresar" prefHeight="40.0" prefWidth="150.0" styleClass="btn--outline-teal" text="&lt; Regresar" />
                  <AnchorPane HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnContinue" mnemonicParsing="false" onAction="#handleContinue" prefHeight="40.0" prefWidth="150.0" styleClass="btn--success-shadow" text="Continuar" />
               </children>
               <padding>
                  <Insets bottom="10.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
