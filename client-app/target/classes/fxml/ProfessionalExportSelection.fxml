<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="350.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.piedraazul.app_client.controllers.ProfessionalExportSelectionController">
    <children>
        <!-- Panel de Encabezado -->
        <Pane prefHeight="110.0" prefWidth="700.0" style="-fx-background-color: #5947FF;">
            <children>
                <Label layoutX="185.0" layoutY="38.0" text="FORMATO DE EXPORTACIÓN" textFill="WHITE">
                    <font>
                        <Font name="Cascadia Code Bold" size="24.0" />
                    </font>
                </Label>
            </children>
        </Pane>

        <!-- Contenido principal -->
        <VBox layoutY="110.0" spacing="25.0"
              AnchorPane.leftAnchor="25.0" AnchorPane.rightAnchor="25.0"
              AnchorPane.topAnchor="125.0" AnchorPane.bottomAnchor="20.0">
            <padding>
                <Insets top="15.0" />
            </padding>
            <children>
                <Label text="Escoja el formato en el que requiere exportar los datos de las citas médicas">
                    <font>
                        <Font name="Cascadia Code Regular" size="14.0" />
                    </font>
                </Label>

                <!-- Botones de formato de exportación -->
                <HBox alignment="CENTER" spacing="40.0">
                    <children>
                        <Button fx:id="button_Json" mnemonicParsing="false" onAction="#handleExportJson"
                                prefHeight="50.0" prefWidth="200.0"
                                style="-fx-background-color: #5947FF;" text="Formato JSON" textFill="WHITE">
                            <font>
                                <Font name="Cascadia Code Bold" size="14.0" />
                            </font>
                        </Button>

                        <Button fx:id="button_Html" mnemonicParsing="false" onAction="#handleExportHtml"
                                prefHeight="50.0" prefWidth="200.0"
                                style="-fx-background-color: #5947FF;" text="Formato HTML" textFill="WHITE">
                            <font>
                                <Font name="Cascadia Code Bold" size="14.0" />
                            </font>
                        </Button>
                    </children>
                </HBox>

                <!-- Botón regresar -->
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Button fx:id="button_Back" mnemonicParsing="false" onAction="#handleBack"
                                style="-fx-background-color: #E8E8E8;" text="&lt;- Regresar">
                            <font>
                                <Font name="Cascadia Code Regular" size="14.0" />
                            </font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>