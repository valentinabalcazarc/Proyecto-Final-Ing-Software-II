<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<VBox prefHeight="486.0" prefWidth="593.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.piedraazul.app_client.controllers.LoginController">
   <children>

      <!-- ══ HEADER ══ -->
      <AnchorPane prefHeight="120.0" prefWidth="593.0" styleClass="header--blue">
         <children>
            <VBox alignment="CENTER"
                  AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
               <children>
                  <Label text="PIEDRA AZUL" textFill="WHITE">
                     <font><Font name="Cascadia Code Bold" size="34.0" /></font>
                  </Label>
                  <Label text="Servicios Médicos" textFill="WHITE">
                     <font><Font name="Cascadia Code Bold" size="17.0" /></font>
                  </Label>
               </children>
            </VBox>
         </children>
      </AnchorPane>

      <!-- ══ BODY ══ -->
      <AnchorPane VBox.vgrow="ALWAYS" prefWidth="593.0" styleClass="page--white">
         <children>
            <VBox alignment="CENTER" spacing="0.0"
                  AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
               <children>

                  <!-- ── Tarjeta central ── -->
                  <VBox styleClass="login__card" spacing="20.0" maxWidth="380.0">
                     <children>

                        <!-- Título de bienvenida -->
                        <Label text="BIENVENIDO" styleClass="login__title">
                           <font><Font name="Cascadia Code Bold" size="18.0" /></font>
                        </Label>

                        <!-- Campo: Usuario -->
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Usuario (cédula):">
                                 <font><Font name="Cascadia Code" size="13.0" /></font>
                              </Label>
                              <TextField fx:id="txtUser_login"
                                         maxWidth="Infinity"
                                         styleClass="textfield--styled"
                                         promptText="Ingrese su número de cédula">
                                 <font><Font name="Cascadia Code" size="13.0" /></font>
                              </TextField>
                           </children>
                        </VBox>

                        <!-- Campo: Contraseña -->
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Contraseña:">
                                 <font><Font name="Cascadia Code" size="13.0" /></font>
                              </Label>
                              <PasswordField fx:id="txtPass_Login"
                                             maxWidth="Infinity"
                                             styleClass="textfield--styled"
                                             promptText="Ingrese su contraseña">
                                 <font><Font name="Cascadia Code" size="13.0" /></font>
                              </PasswordField>
                           </children>
                        </VBox>

                        <!-- Botón Ingresar -->
                        <Button fx:id="btnInicio_Sesion"
                                maxWidth="Infinity"
                                mnemonicParsing="false"
                                onAction="#handleLogin"
                                prefHeight="36.0"
                                styleClass="btn--primary"
                                text="Ingresar">
                           <font><Font name="Cascadia Code Bold" size="14.0" /></font>
                        </Button>

                        <!-- Separador y registro -->
                        <VBox alignment="CENTER" spacing="8.0">
                           <children>
                              <Label text="¿No tienes cuenta? Regístrate aquí"
                                     styleClass="login__register-hint">
                                 <font><Font name="Cascadia Code" size="12.0" /></font>
                              </Label>
                              <Button fx:id="btnRegister_Login"
                                      maxWidth="Infinity"
                                      mnemonicParsing="false"
                                      onAction="#handleRegister"
                                      prefHeight="34.0"
                                      styleClass="btn--secondary"
                                      text="Registrarse">
                                 <font><Font name="Cascadia Code" size="13.0" /></font>
                              </Button>
                           </children>
                        </VBox>

                     </children>
                     <padding><Insets top="30.0" right="35.0" bottom="30.0" left="35.0" /></padding>
                  </VBox>

               </children>
            </VBox>
         </children>
      </AnchorPane>

   </children>
</VBox>
