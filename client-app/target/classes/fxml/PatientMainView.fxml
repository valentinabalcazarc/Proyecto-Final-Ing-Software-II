<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<VBox prefHeight="400.0" prefWidth="620.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.piedraazul.app_client.controllers.PatientMainController">
   <children>

      <!-- ══ HEADER ══ -->
      <AnchorPane prefHeight="110.0" prefWidth="620.0" styleClass="header--patient-gradient">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="0.0"
                  AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
               <children>

                  <!-- Títulos del header (lado izquierdo) -->
                  <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" spacing="4.0">
                     <children>
                        <Label text="MENÚ PRINCIPAL" textFill="WHITE">
                           <font><Font name="Cascadia Code Bold" size="26.0" /></font>
                        </Label>
                        <Label text="Panel del Paciente" textFill="#dce0ff">
                           <font><Font name="Cascadia Code" size="14.0" /></font>
                        </Label>
                     </children>
                     <padding><Insets left="30.0" /></padding>
                  </VBox>

                  <!-- Botón Cerrar Sesión (lado derecho) -->
                  <Button fx:id="btnCerrarSesion"
                          mnemonicParsing="false"
                          onAction="#handleCerrarSesion"
                          prefHeight="36.0" prefWidth="140.0"
                          styleClass="btn--ghost-white"
                          text="Cerrar Sesión">
                     <font><Font name="Cascadia Code Bold" size="13.0" /></font>
                     <HBox.margin><Insets right="25.0" /></HBox.margin>
                  </Button>

               </children>
            </HBox>
         </children>
      </AnchorPane>

      <!-- ══ BODY ══ -->
      <AnchorPane VBox.vgrow="ALWAYS" prefWidth="620.0" styleClass="page--gradient-light">
         <children>
            <VBox alignment="CENTER" spacing="24.0"
                  AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
               <children>

                  <!-- Subtítulo de sección -->
                  <Label text="Servicios Médicos Piedra Azul"
                         styleClass="patient-main__section-title">
                     <font><Font name="Cascadia Code Bold" size="15.0" /></font>
                  </Label>

                  <!-- Tarjetas de acciones -->
                  <HBox alignment="CENTER" spacing="28.0">
                     <children>

                        <!-- Tarjeta: Agendar Cita -->
                        <VBox styleClass="patient-main__action-card" alignment="CENTER" spacing="12.0"
                              prefWidth="200.0" prefHeight="140.0">
                           <children>
                              <Label text="📅" styleClass="patient-main__card-icon">
                                 <font><Font size="32.0" /></font>
                              </Label>
                              <Button fx:id="btnAddAppointment"
                                      mnemonicParsing="false"
                                      onAction="#handleAddAppointment"
                                      prefHeight="38.0" maxWidth="Infinity"
                                      styleClass="btn--patient-primary"
                                      text="Agendar Cita">
                                 <font><Font name="Cascadia Code Bold" size="13.0" /></font>
                              </Button>
                           </children>
                           <padding><Insets top="20.0" right="20.0" bottom="20.0" left="20.0" /></padding>
                        </VBox>

                        <!-- Tarjeta: Ver Mis Citas -->
                        <VBox styleClass="patient-main__action-card" alignment="CENTER" spacing="12.0"
                              prefWidth="200.0" prefHeight="140.0">
                           <children>
                              <Label text="🗒️" styleClass="patient-main__card-icon">
                                 <font><Font size="32.0" /></font>
                              </Label>
                              <Button fx:id="btnViewAppointments"
                                      mnemonicParsing="false"
                                      onAction="#handleViewAppointments"
                                      prefHeight="38.0" maxWidth="Infinity"
                                      styleClass="btn--patient-outline"
                                      text="Ver Mis Citas">
                                 <font><Font name="Cascadia Code Bold" size="13.0" /></font>
                              </Button>
                           </children>
                           <padding><Insets top="20.0" right="20.0" bottom="20.0" left="20.0" /></padding>
                        </VBox>

                     </children>
                  </HBox>

               </children>
            </VBox>
         </children>
      </AnchorPane>

   </children>
</VBox>