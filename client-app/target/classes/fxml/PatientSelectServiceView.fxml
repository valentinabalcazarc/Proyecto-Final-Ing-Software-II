<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.piedraazul.app_client.controllers.PatientSelectServiceController">
    <children>
        <AnchorPane prefHeight="100.0" prefWidth="800.0" style="-fx-background-color: #6666FF;">
            <children>
                <VBox alignment="CENTER_LEFT" layoutX="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <Label text="Asistente de agendamiento" textFill="WHITE">
                            <font>
                                <Font name="Segoe UI Bold" size="18.0" />
                            </font>
                        </Label>
                        <Label text="Programa tu cita ahora" textFill="WHITE">
                            <font>
                                <Font name="Segoe UI" size="14.0" />
                            </font>
                            <VBox.margin>
                                <Insets top="5.0" />
                            </VBox.margin>
                        </Label>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
        <AnchorPane prefHeight="500.0" prefWidth="800.0" style="-fx-background-color: white;">
            <children>
                <VBox spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="20.0">
                    <children>
                        <Label text="Selecciona tu servicio:">
                            <font>
                                <Font name="Segoe UI Bold" size="14.0" />
                            </font>
                        </Label>
                        
                        <VBox alignment="CENTER" spacing="15.0">
                            <children>
                                <HBox alignment="CENTER" spacing="15.0">
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#handleTerapiaNeutral" prefHeight="80.0" prefWidth="230.0" style="-fx-background-color: #CC9900;" text="Terapia neutral" textFill="WHITE">
                                            <font>
                                                <Font name="Segoe UI Bold" size="14.0" />
                                            </font>
                                        </Button>
                                        <TextArea editable="false" prefHeight="80.0" prefWidth="350.0" style="-fx-control-inner-background: #F5D473; -fx-background-color: transparent; -fx-padding: 5;" text="Tratamiento que ayuda a aliviar dolores e &#10;inflamaciones mediante pequeñas aplicaciones&#10;que buscan mejorar el funcionamiento del cuerpo&#10;y el sistema nervioso." wrapText="true">
                                            <font>
                                                <Font name="Segoe UI" size="12.0" />
                                            </font>
                                        </TextArea>
                                    </children>
                                </HBox>
                                
                                <HBox alignment="CENTER" spacing="15.0">
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#handleQuiropractica" prefHeight="80.0" prefWidth="230.0" style="-fx-background-color: #669900;" text="Quiropractica" textFill="WHITE">
                                            <font>
                                                <Font name="Segoe UI Bold" size="14.0" />
                                            </font>
                                        </Button>
                                        <TextArea editable="false" prefHeight="80.0" prefWidth="350.0" style="-fx-control-inner-background: #B0D26C; -fx-background-color: transparent; -fx-padding: 5;" text="Terapia manual que ayuda a aliviar dolores&#10;de espalda, cuello y articulaciones, &#10;mejorando la postura y el movimiento." wrapText="true">
                                            <font>
                                                <Font name="Segoe UI" size="12.0" />
                                            </font>
                                        </TextArea>
                                    </children>
                                </HBox>
                                
                                <HBox alignment="CENTER" spacing="15.0">
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#handleFisioterapia" prefHeight="80.0" prefWidth="230.0" style="-fx-background-color: #993300;" text="Fisioterapia" textFill="WHITE">
                                            <font>
                                                <Font name="Segoe UI Bold" size="14.0" />
                                            </font>
                                        </Button>
                                        <TextArea editable="false" prefHeight="80.0" prefWidth="350.0" style="-fx-control-inner-background: #E89A73; -fx-background-color: transparent; -fx-padding: 5;" text="Tratamiento con ejercicios y movimientos suaves&#10;que ayuda a recuperar fuerza, movilidad y &#10;disminuir el dolor después de una lesión o&#10;molestia." wrapText="true">
                                            <font>
                                                <Font name="Segoe UI" size="12.0" />
                                            </font>
                                        </TextArea>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        
                        <Button mnemonicParsing="false" onAction="#handleRegresar" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #E8E8E8;" text="&lt;- Regresar">
                            <font>
                                <Font name="Cascadia Code" size="14.0" />
                            </font>
                            <VBox.margin>
                                <Insets top="30.0" />
                            </VBox.margin>
                        </Button>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</VBox>
