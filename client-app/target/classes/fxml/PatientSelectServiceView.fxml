<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.piedraazul.app_client.controllers.PatientSelectServiceController">
    <children>
        <AnchorPane prefHeight="100.0" prefWidth="800.0" styleClass="header--blue">
            <children>
                <VBox alignment="CENTER_LEFT" layoutX="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <Label text="Asistente de agendamiento" textFill="WHITE">
                            <font>
                                <Font name="Segoe UI Bold" size="18.0" />
                            </font>
                        </Label>
                        <Label text="Programa tu cita ahora" textFill="WHITE">
                            <font>
                                <Font name="Segoe UI" size="14.0" />
                            </font>
                            <VBox.margin>
                                <Insets top="5.0" />
                            </VBox.margin>
                        </Label>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
        <AnchorPane prefHeight="500.0" prefWidth="800.0" styleClass="page--white">
            <children>
                <VBox spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="20.0">
                    <children>
                        <Label text="Selecciona tu servicio:">
                            <font>
                                <Font name="Segoe UI Bold" size="14.0" />
                            </font>
                        </Label>
                        
                        <VBox alignment="CENTER" spacing="15.0">
                            <children>
                                <HBox alignment="CENTER" spacing="15.0">
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#handleTerapiaNeutral" prefHeight="80.0" prefWidth="230.0" styleClass="service__btn--neutral" text="Terapia neutral">
                                            <font>
                                                <Font name="Segoe UI Bold" size="14.0" />
                                            </font>
                                        </Button>
                                        <TextArea editable="false" prefHeight="80.0" prefWidth="350.0" styleClass="service__textarea--neutral" text="Tratamiento que ayuda a aliviar dolores e &#10;inflamaciones mediante pequeñas aplicaciones&#10;que buscan mejorar el funcionamiento del cuerpo&#10;y el sistema nervioso." wrapText="true">
                                            <font>
                                                <Font name="Segoe UI" size="12.0" />
                                            </font>
                                        </TextArea>
                                    </children>
                                </HBox>
                                
                                <HBox alignment="CENTER" spacing="15.0">
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#handleQuiropractica" prefHeight="80.0" prefWidth="230.0" styleClass="service__btn--chiropractic" text="Quiropractica">
                                            <font>
                                                <Font name="Segoe UI Bold" size="14.0" />
                                            </font>
                                        </Button>
                                        <TextArea editable="false" prefHeight="80.0" prefWidth="350.0" styleClass="service__textarea--chiropractic" text="Terapia manual que ayuda a aliviar dolores&#10;de espalda, cuello y articulaciones, &#10;mejorando la postura y el movimiento." wrapText="true">
                                            <font>
                                                <Font name="Segoe UI" size="12.0" />
                                            </font>
                                        </TextArea>
                                    </children>
                                </HBox>
                                
                                <HBox alignment="CENTER" spacing="15.0">
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#handleFisioterapia" prefHeight="80.0" prefWidth="230.0" styleClass="service__btn--physiotherapy" text="Fisioterapia">
                                            <font>
                                                <Font name="Segoe UI Bold" size="14.0" />
                                            </font>
                                        </Button>
                                        <TextArea editable="false" prefHeight="80.0" prefWidth="350.0" styleClass="service__textarea--physiotherapy" text="Tratamiento con ejercicios y movimientos suaves&#10;que ayuda a recuperar fuerza, movilidad y &#10;disminuir el dolor después de una lesión o&#10;molestia." wrapText="true">
                                            <font>
                                                <Font name="Segoe UI" size="12.0" />
                                            </font>
                                        </TextArea>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        
                        <Button mnemonicParsing="false" onAction="#handleRegresar" prefHeight="35.0" prefWidth="150.0" styleClass="btn--secondary" text="&lt;- Regresar">
                            <font>
                                <Font name="Cascadia Code" size="14.0" />
                            </font>
                            <VBox.margin>
                                <Insets top="30.0" />
                            </VBox.margin>
                        </Button>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</VBox>
