<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" styleClass="page--gray" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.piedraazul.app_client.controllers.ProfessionalManageAppointmentsController">
   <children>
      <VBox layoutX="40.0" layoutY="30.0" prefHeight="540.0" prefWidth="720.0" spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="30.0">
         <children>
            <VBox alignment="CENTER" spacing="5.0" styleClass="header--blue-rounded">
               <children>
                  <Label text="GESTIONAR CITA" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="26.0" />
                     </font>
                  </Label>
               </children>
               <padding>
                  <Insets bottom="15.0" top="15.0" />
               </padding>
            </VBox>
            
            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="card--search">
               <children>
                  <Label text="Cédula del paciente:">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Label>
                  <TextField fx:id="txtCedula" prefHeight="35.0" prefWidth="250.0" promptText="Ingrese identificación" />
                  <Button mnemonicParsing="false" onAction="#handleFind" prefHeight="35.0" prefWidth="100.0" styleClass="btn--indigo" text="Buscar" />
               </children>
            </HBox>
            
            <VBox spacing="10.0" VBox.vgrow="ALWAYS">
               <children>
                  <Label text="Seleccione la cita que desea alterar:" textFill="#555555">
                     <font>
                        <Font name="System Italic" size="13.0" />
                     </font>
                  </Label>
                  <TableView fx:id="tblAppointments" prefHeight="200.0" prefWidth="200.0" styleClass="table--rounded" VBox.vgrow="ALWAYS">
                    <columns>
                       <TableColumn fx:id="colId" prefWidth="80.0" text="ID Cita" />
                       <TableColumn fx:id="colDate" prefWidth="110.0" text="Fecha" />
                       <TableColumn fx:id="colTime" prefWidth="100.0" text="Hora" />
                       <TableColumn fx:id="colPatientName" text="Paciente" prefWidth="150"/>
                       <TableColumn fx:id="colProfessional" text="Profesional" prefWidth="150"/>
                       <TableColumn fx:id="colType" text="Tipo" prefWidth="100"/>
                       <TableColumn fx:id="colSpeciality" text="Especialidad" prefWidth="120"/>
                       <TableColumn fx:id="colStatus" prefWidth="150.0" text="Estado" />
                       <TableColumn fx:id="colDescription" prefWidth="155.0" text="Descripción" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
            
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleReturn" prefHeight="40.0" prefWidth="150.0" styleClass="btn--light-clear" text="&lt;- Regresar" />
                  <AnchorPane HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleReschedule" prefHeight="40.0" prefWidth="150.0" styleClass="btn--indigo" text="Reagendar" />
                  <Button mnemonicParsing="false" onAction="#handleCancel" prefHeight="40.0" prefWidth="150.0" styleClass="btn--danger-cancel" text="Cancelar cita" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
