<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="500.0" prefWidth="750.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.piedraazul.app_client.controllers.PatientViewAppointmentsController"
            styleClass="page--gradient-light">
    <children>

        <!-- Header azul -->
        <Pane prefHeight="100.0" prefWidth="750.0" styleClass="header--patient-gradient">
            <children>
                <Label layoutX="40.0" layoutY="30.0" text="VER MIS CITAS" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                </Label>
                <Button fx:id="btnRegresar" layoutX="600.0" layoutY="30.0"
                        mnemonicParsing="false" onAction="#handleRegresar"
                        prefHeight="40.0" prefWidth="120.0"
                        styleClass="btn--ghost-white"
                        text="← Regresar">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
            </children>
        </Pane>

        <!-- Contenido -->
        <Pane layoutX="30.0" layoutY="120.0" prefHeight="350.0" prefWidth="690.0" styleClass="card">
            <children>
                <Label layoutX="20.0" layoutY="20.0" text="CITAS PROGRAMADAS:" textFill="#444444">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>

                <TableView fx:id="tblAppointments" layoutX="20.0" layoutY="60.0" prefHeight="220.0" prefWidth="650.0" styleClass="table--bordered">
                    <columns>
                        <TableColumn fx:id="colDate" prefWidth="120.0" text="Fecha" />
                        <TableColumn fx:id="colTime" prefWidth="100.0" text="Hora" />
                        <TableColumn fx:id="colProfessional" prefWidth="230.0" text="Profesional" />
                        <TableColumn fx:id="colStatus" prefWidth="180.0" text="Estado" />
                    </columns>
                </TableView>

                <HBox layoutX="20.0" layoutY="300.0" spacing="20.0">
                    <children>
                        <Button fx:id="btnCancelAppointment" mnemonicParsing="false" onAction="#handleCancelAppointment"
                                prefHeight="35.0" prefWidth="160.0"
                                styleClass="btn--danger-rounded"
                                text="Cancelar Cita" />
                        
                        <Button fx:id="btnReschedule" mnemonicParsing="false" onAction="#handleReschedule"
                                prefHeight="35.0" prefWidth="160.0"
                                styleClass="btn--warning-rounded"
                                text="Reagendar Cita" />
                    </children>
                </HBox>
            </children>
        </Pane>

    </children>
</AnchorPane>
