<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.layout.Pane?>
<VBox prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.piedraazul.app_client.controllers.PatientAutomaticRecommendationController">
    <children>
        <AnchorPane prefHeight="100.0" prefWidth="800.0" style="-fx-background-color: #6666FF;">
            <children>
                <VBox alignment="CENTER_LEFT" layoutX="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <Label text="Asistente de agendamiento" textFill="WHITE">
                            <font>
                                <Font name="Cascadia Code Bold" size="18.0" />
                            </font>
                        </Label>
                        <Label text="Programa tu cita ahora" textFill="WHITE">
                            <font>
                                <Font name="Cascadia Code" size="14.0" />
                            </font>
                            <VBox.margin>
                                <Insets top="5.0" />
                            </VBox.margin>
                        </Label>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
        <AnchorPane prefHeight="500.0" prefWidth="800.0" style="-fx-background-color: white;">
            <children>
                <VBox layoutX="50.0" layoutY="20.0" prefWidth="700.0" spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="20.0">
                    <children>
                        <Label text="La cita mas cercana disponible es:">
                            <font>
                                <Font name="Cascadia Code" size="14.0" />
                            </font>
                        </Label>
                        
                        <VBox alignment="CENTER_LEFT" prefHeight="150.0" prefWidth="700.0" spacing="15.0" style="-fx-background-color: #DDDDDD; -fx-padding: 20; -fx-border-color: #AAAAAA; -fx-border-width: 1;">
                            <children>
                                <Label fx:id="lblFecha" text="Cargando...">
                                    <font>
                                        <Font name="Segoe UI Symbol" size="16.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblHora" text="Cargando...">
                                    <font>
                                        <Font name="Segoe UI Symbol" size="16.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblProfesional" text="Cargando...">
                                    <font>
                                        <Font name="Segoe UI Symbol" size="16.0" />
                                    </font>
                                </Label>
                            </children>
                            <VBox.margin>
                                <Insets left="30.0" right="30.0" />
                            </VBox.margin>
                        </VBox>
                        
                        <Button mnemonicParsing="false" onAction="#handleOtrosHorarios" prefHeight="35.0" prefWidth="280.0" style="-fx-background-color: #D94F4F;" text="Ver otros horarios disponibles" textFill="WHITE">
                            <font>
                                <Font name="Cascadia Code" size="14.0" />
                            </font>
                            <VBox.margin>
                                <Insets left="30.0" top="10.0" />
                            </VBox.margin>
                        </Button>
                        
                        <Pane VBox.vgrow="ALWAYS" />
                        
                        <HBox alignment="CENTER" spacing="250.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#handleRegresar" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #E8E8E8;" text="&lt;- Regresar">
                                    <font>
                                        <Font name="Cascadia Code" size="14.0" />
                                    </font>
                                </Button>
                                <Button fx:id="btnConfirmar" mnemonicParsing="false" onAction="#handleConfirmar" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #66CC00;" text="Confirmar cita" textFill="WHITE">
                                    <font>
                                        <Font name="Cascadia Code" size="14.0" />
                                    </font>
                                </Button>
                            </children>
                            <VBox.margin>
                                <Insets top="20.0" />
                            </VBox.margin>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</VBox>
